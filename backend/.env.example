# ═══════════════════════════════════════════════════
# SmartStudyInstructor — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# Kaggle Distributed Cloud Rendering (Optional)
# If provided, heavy video generation (Playwright+FFmpeg) will be offloaded to this Ngrok URL.
# Example: CLOUD_RENDER_URL=https://1234-56-78.ngrok-free.app
CLOUD_RENDER_URL=

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database
DATABASE_URL=sqlite:///./smart_study.db
SQLALCHEMY_ECHO=False

# Server
DEBUG=True
HOST=0.0.0.0
PORT=8000

# File Paths
UPLOAD_FOLDER=static/uploads
PDF_UPLOAD_FOLDER=static/uploads/pdfs
EVIDENCE_FOLDER=static/uploads/evidence
MODELS_FOLDER=static/models

# YOLO Model
YOLO_MODEL_PATH=static/models/yolov8n.pt

# ChromaDB
CHROMA_DB_PATH=./chroma_data

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Asset API Keys
PEXELS_API_KEY=your_pexels_api_key_here
GIPHY_API_KEY=your_giphy_api_key_here

# Output folders
AUDIO_FOLDER=static/audio
VIDEO_FOLDER=static/videos

# EchoMimicV2 Colab GPU Service (legacy)
COLAB_ECHOMIMIC_URL=

# HeyGen API Key for Video Generation (optional, paid)
HEYGEN_API_KEY=

# ═══════════════════════════════════════════════════
# OmniAvatar Colab GPU Service (FREE, open-source)
# ═══════════════════════════════════════════════════
# Set to ngrok URL from OmniAvatar_SmartStudy_Colab.ipynb
# Example: COLAB_AVATAR_URL=https://abc123.ngrok-free.app
COLAB_AVATAR_URL=https://xxxx.ngrok-free.app
AVATAR_IMAGE_PATH=static/avatars/teacher_avatar.jpg
VIDEO_OUTPUT_DIR=static/videos
