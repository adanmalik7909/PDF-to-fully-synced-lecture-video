<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SmartStudyInstructor — {{ scene.topic }}</title>
    <style>
        {% include '_base.css.j2' %}
        
        /* Premium DNA Transition Styles */
        body { opacity: 0; }
        body.scene-ready { opacity: 1; transition: opacity 0.5s ease; }
        
        /* Grid Column defaults */
        :root {
            --col-left: 40%;
            --col-right: 60%;
        }
    </style>
    
    <!-- ── GSAP & motion CDNs ── -->
    {% include '_gsap_head.html.j2' %}
    
    {% block head %}{% endblock %}
</head>
<body class="scene-ready">

<!-- ── Timelines JSON ── -->
<script>
    window.TIMELINE_DATA = {{ timeline_data | tojson }};
    window.DIAGRAM_DATA = {{ scene.diagram_data | default({}) | tojson }};
</script>

<div id="analogy-overlay" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;opacity:0;transition:opacity 0.6s ease"></div>
<div id="attention-hook-box"></div>

<!-- ── Main Grid Container ── -->
{% block content %}{% endblock %}

<!-- ── Dynamic Avatar (FFmpeg overlaid) ── -->
{% if scene.avatar_path %}
    {% set avatar_cfg = scene.avatar_config | default({}) %}
    {% set is_hidden = avatar_cfg.hidden_for_ffmpeg | default(False) %}
    {% set avatar_size = avatar_cfg.size | default(130) %}
    {% set ring_color = avatar_cfg.ring | default('#4F8EF7') %}
    <div id="avatar-ring" style="position: absolute; border: 2px solid {{ ring_color }}; border-radius: 50%; opacity: 0; pointer-events: none; z-index: 50; width: {{ avatar_size + 18 }}px; height: {{ avatar_size + 18 }}px; display: {{ 'none' if is_hidden else 'block' }};"></div>
    <img id="avatar" src="{{ scene.avatar_path }}" alt="Instructor" style="position: absolute; border-radius: 50%; object-fit: cover; opacity: {{ 0 if is_hidden else 1 }}; pointer-events: none; z-index: 50; width: {{ avatar_size }}px; height: {{ avatar_size }}px; left: 28px; bottom: 28px; border: 3px solid #C9B99A; display: {{ 'none' if is_hidden else 'block' }};" />
{% endif %}

<!-- ── Scene Transition Flash ── -->
<div id="scene-flash" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; opacity: 0; pointer-events: none; z-index: 9999;"></div>

<!-- ── Full-screen teacher drawing layers ── -->
{% include '_gsap_layers.html.j2' %}

<!-- ── Master GSAP Animation Engine ── -->
<script>
    {% include '_timeline_engine.js.j2' %}
</script>

{% block scripts %}{% endblock %}
</body>
</html>
