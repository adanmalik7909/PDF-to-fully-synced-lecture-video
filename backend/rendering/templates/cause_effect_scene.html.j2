{% extends '_base.html.j2' %}

{% block head %}
<style>
    .cause-effect-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        width: 100%;
        height: 100%;
        position: relative;
        background: var(--navy);
    }
    
    .panel-cause {
        padding: 80px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-right: 1px dashed rgba(255,255,255,0.15);
        position: relative;
    }
    
    .panel-effect {
        background: var(--cream);
        color: var(--dark-text);
        padding: 80px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }
    
    .cause-box {
        border: 2px solid #FF3B3B;
        background: rgba(255, 59, 59, 0.05);
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 0 30px rgba(255, 59, 59, 0.15);
        margin-top: 40px;
        opacity: 0;
        transform: scale(0.9);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    
    .cause-box.active {
        opacity: 1;
        transform: scale(1);
    }
    
    .effect-box {
        border: 2px solid #10B981;
        background: rgba(16, 185, 129, 0.05);
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 0 30px rgba(16, 185, 129, 0.15);
        margin-top: 40px;
        opacity: 0;
        transform: scale(0.9);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    
    .effect-box.active {
        opacity: 1;
        transform: scale(1);
    }
    
    #connector-arrow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 30;
        width: 120px;
        height: 60px;
        pointer-events: none;
    }
</style>
{% endblock %}

{% block content %}
<div class="cause-effect-grid">
    
    <!-- LEFT PANEL: Cause -->
    <div class="panel-cause">
        <div class="topic-chip">{{ scene.topic }}</div>
        
        <h1 class="slide-heading playfair" style="font-size: 42px;">
            {{ scene.heading_left }}
        </h1>
        
        <p class="slide-description inter">
            {{ scene.left_description }}
        </p>
        
        <div class="cause-box" id="cause-panel-target">
            <h3 class="playfair" style="color: #FF3B3B; font-size: 24px; margin-bottom: 12px;">⚠️ The Triggering Cause</h3>
            <div class="inter" style="font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.85);">
                {{ scene.bullets[0].text if scene.bullets else 'The root causative event or variable.' }}
            </div>
        </div>
        
        <div class="scene-counter">
            Scene {{ "%02d"|format(scene.scene_index) }} / {{ "%02d"|format(scene.total_scenes) }}
        </div>
    </div>
    
    <!-- RIGHT PANEL: Effect -->
    <div class="panel-effect">
        <div class="progress-strip">
            <div class="progress-fill" style="width:{{ (scene.scene_index / scene.total_scenes * 100)|round }}%;"></div>
        </div>
        
        <h2 class="slide-heading-right playfair" style="font-size: 38px; color: var(--navy); margin-bottom: 24px;">
            {{ scene.heading_right }}
        </h2>
        
        <p class="inter" style="font-size: 18px; line-height: 1.7; color: var(--muted-text); margin-bottom: 20px;">
            How the variables adapt under cascade triggers:
        </p>
        
        <div class="effect-box" id="effect-panel-target">
            <h3 class="playfair" style="color: #10B981; font-size: 24px; margin-bottom: 12px;">✅ The Resulting Effect</h3>
            <div class="inter" style="font-size: 17px; line-height: 1.6; color: var(--dark-text);">
                {{ scene.bullets[1].text if (scene.bullets and scene.bullets|length > 1) else 'The downstream impact or resolution.' }}
            </div>
        </div>
        
        <!-- Key Takeaway bar -->
        <div id="takeaway-bar" style="position: absolute; bottom: 0; left: 0; right: 0; background: var(--navy); color: var(--white); padding: 18px 40px; display: flex; gap: 16px; align-items: center; border-top: 2px solid var(--gold);">
            <span class="takeaway-label inter" style="color: var(--gold); font-weight: 800; font-size: 14px; text-transform: uppercase;">Key Takeaway</span>
            <span class="takeaway-text inter" style="font-size: 16px; font-weight: 500;">{{ scene.takeaway }}</span>
        </div>
    </div>
    
    <!-- Bold Dynamic Connector Arrow -->
    <svg id="connector-arrow" viewBox="0 0 120 60">
        <defs>
            <marker id="cause-arrowhead" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                <polygon points="0 0, 6 3, 0 6" fill="#4F8EF7"/>
            </marker>
        </defs>
        <path id="arrow-path" d="M 10 30 L 110 30" stroke="#4F8EF7" stroke-width="4" fill="none" marker-end="url(#cause-arrowhead)" stroke-dasharray="100" stroke-dashoffset="100" style="transition: stroke-dashoffset 0.8s ease;"/>
    </svg>
    
</div>
{% endblock %}
