<!-- ── Full-screen Teacher Draw SVG Layer ── -->
<svg id="teacher-draw-svg"
     style="position:absolute;top:0;left:0;width:100%;height:100%;
            pointer-events:none;z-index:100;overflow:visible">
  <defs>
    <!-- Glow filter for particles and draw strokes -->
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <!-- Arrowhead marker for teacher arrows -->
    <marker id="teacher-arrowhead" markerWidth="10" markerHeight="7"
            refX="10" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#4F8EF7"/>
    </marker>
  </defs>
</svg>

<!-- ── Teacher Typewriter Write Box ── -->
<div id="teacher-write-box" style="
  position:absolute;display:none;z-index:101;
  font-family:'Playfair Display',serif;font-size:clamp(14px,2vw,22px);
  color:#FFD700;font-weight:700;
  text-shadow:0 0 10px rgba(255,215,0,0.5);
  background:rgba(44,62,80,0.88);
  padding:8px 18px;border-radius:10px;
  border-left:3px solid #C9B99A;
  backdrop-filter:blur(6px);
  -webkit-backdrop-filter:blur(6px);
  white-space:nowrap;
  pointer-events:none;
"></div>

<!-- ── Laser Pointer Dot ── -->
<div id="laser-pointer" style="
  position:fixed;width:14px;height:14px;
  border-radius:50%;background:#FF3B3B;
  display:none;z-index:200;
  box-shadow:0 0 8px #FF3B3B,0 0 20px rgba(255,59,59,0.6);
  pointer-events:none;
  transform:translate(-50%,-50%);
"></div>
