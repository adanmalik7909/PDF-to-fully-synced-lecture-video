/* ═══════════════════════════════════════════════════════════════
   SmartStudyInstructor V12.5 — GSAP Hybrid Timeline Engine
   
   Reads TIMELINE_DATA from Python's TimelineBuilder.
   Uses GSAP 3.15 for professional spring/elastic animations
   while keeping requestAnimationFrame tick loop for event firing.
   
   SUBTITLE STRATEGY:
     FFmpeg burns SRT subtitles (synced with audio).
     
   Runs via requestAnimationFrame for frame-perfect Playwright capture.
═══════════════════════════════════════════════════════════════ */

(function () {
    'use strict';

    /* ─── Parse timeline data ──────────────────────────────── */
    const TD       = window.TIMELINE_DATA || {};
    const timeline = TD.events || [];
    const totalMs  = TD.total_duration_ms || 10000;

    const startTime  = performance.now();
    const firedFlags = new Array(timeline.length).fill(false);

    /* ─── Util ─────────────────────────────────────────────── */
    const $ = id => document.getElementById(id);
    const q = sel => document.querySelector(sel);
    const qa = sel => document.querySelectorAll(sel);
    const now = () => performance.now() - startTime;

    /* ─── GSAP availability check ──────────────────────────── */
    const G = typeof gsap !== 'undefined' ? gsap : null;

    /* ─── Visual Glow Helpers ──────────────────────────────── */
    function clearGlowProperties(el) {
        if (!el) return;
        if (G) {
            G.set(el, { clearProps: "scale,color,textShadow,backgroundColor,borderRadius,padding,transform,fontWeight" });
        } else {
            el.style.color = '';
            el.style.textShadow = '';
            el.style.backgroundColor = '';
            el.style.borderRadius = '';
            el.style.padding = '';
            el.style.transform = '';
            el.style.scale = '';
            el.style.fontWeight = '';
        }
    }

    function cleanupGlowsInContainer(container) {
        if (!container) return;
        const glows = container.querySelectorAll('.zoom-word-inline');
        glows.forEach(glow => {
            if (G) G.killTweensOf(glow);
            clearGlowProperties(glow);
        });
    }

    /* ─── Fade scene in ────────────────────────────────────── */
    document.body.classList.add('scene-ready');

    /* ═══════════════════════════════════════════════════════════
       EVENT HANDLERS
       Each handler matches event_type from timeline_builder.py
    ═══════════════════════════════════════════════════════════ */

    function handleEvent(ev) {
        const t    = ev.event_type;
        const d    = ev.data || {};
        const durMs = ev.end_ms - ev.start_ms;

        /* ── scene_start: V13 dynamic avatar sizing ────────── */
        if (t === 'scene_start') {
            const avatar = $('avatar');
            const avatarRing = $('avatar-ring');
            // Skip avatar animation when hidden for FFmpeg lipsync overlay
            const avatarHidden = avatar && getComputedStyle(avatar).display === 'none';
            if (avatar && avatarRing && G && !avatarHidden) {
                // Dynamic cinematic system removed at user's request.
                // The static fallback image will now remain exactly in the bottom-left corner 
                // just like the Kaggle FFmpeg video overlay, without jumping around.
            }
        }
        
        /* ── scene_end: White flash ────────── */
        if (t === 'scene_end') {
            const flash = $('scene-flash');
            if (flash && G) {
                G.fromTo(flash, {opacity: 0}, {opacity: 1, duration: 0.3, yoyo: true, repeat: 1});
            }
        }

        /* ═══════════════════════════════════════════════════════════
           SMARTSTUDYINSTRUCTOR V12.5 — DNA SPECIFIC EVENT HANDLERS
        ═══════════════════════════════════════════════════════════ */

        /* ── heading_glow: DNA-1 Heading Focus ── */
        if (t === 'heading_glow') {
            const heading = $('heading-left') || q('.slide-heading');
            if (heading) {
                if (G) {
                    G.fromTo(heading, 
                        { opacity: 0, y: 30 }, 
                        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', onComplete: () => {
                            const goldWord = heading.querySelector('.gold-word');
                            if (goldWord) {
                                G.to(goldWord, {
                                    color: '#FFD700',
                                    textShadow: '0 0 24px rgba(255,200,0,0.95)',
                                    duration: 0.5,
                                    ease: 'power2.out'
                                });
                            }
                        }}
                    );
                } else {
                    heading.style.opacity = '1';
                }
            }
        }

        /* ── bullet_word_reveal: DNA-1 Karaoke Slide/Fade reveal ── */
        if (t === 'bullet_word_reveal') {
            const idx = d.bullet_index;
            const bullet = $('bullet_' + idx) || q(`.bullet[data-index="${idx}"]`);
            if (bullet) {
                bullet.classList.add('b-visible');
                if (G) {
                    G.fromTo(bullet, 
                        { x: -30, opacity: 0 },
                        { x: 0, opacity: 1, duration: 0.5, ease: 'power3.out' }
                    );
                    const spans = bullet.querySelectorAll('.word-span');
                    if (spans.length > 0) {
                        G.killTweensOf(spans);
                        G.fromTo(spans,
                            { opacity: 0.15, filter: 'blur(3px)', y: 4 },
                            { opacity: 1, filter: 'blur(0px)', y: 0, duration: 0.45, stagger: 0.08, ease: 'power2.out' }
                        );
                    }
                } else {
                    bullet.style.opacity = '1';
                    bullet.querySelectorAll('.word-span').forEach(s => {
                        s.style.opacity = '1';
                        s.style.filter = 'none';
                    });
                }
            }
        }

        /* ── gold_word_pulse: DNA-1 Highlight pulse ── */
        if (t === 'gold_word_pulse') {
            const word = d.word;
            if (word) {
                const wordLower = word.toLowerCase().replace(/[^a-z0-9]/g, '');
                const goldElements = qa('.gold-word');
                let matchedEl = null;
                for (let el of goldElements) {
                    if (el.textContent.toLowerCase().replace(/[^a-z0-9]/g, '').includes(wordLower)) {
                        matchedEl = el;
                        break;
                    }
                }
                if (!matchedEl) {
                    const spans = qa('.word-span, .slide-heading, .slide-description');
                    for (let el of spans) {
                        if (el.textContent.toLowerCase().replace(/[^a-z0-9]/g, '') === wordLower) {
                            matchedEl = el;
                            break;
                        }
                    }
                }
                if (matchedEl) {
                    if (G) {
                        G.fromTo(matchedEl,
                            { scale: 1, color: '#FFD700', textShadow: '0 0 10px rgba(255,215,0,0.4)' },
                            { scale: 1.2, color: '#FFD700', textShadow: '0 0 30px rgba(255,215,0,0.95)', duration: 0.5, yoyo: true, repeat: 1, ease: 'back.out(2)' }
                        );
                    } else {
                        matchedEl.style.color = '#FFD700';
                        matchedEl.style.fontWeight = 'bold';
                        setTimeout(() => { matchedEl.style.color = ''; matchedEl.style.fontWeight = ''; }, 1000);
                    }
                }
            }
        }

        /* ── diagram_enter: Slide in the floating diagram card ── */
        if (t === 'diagram_enter') {
            const diagCard = $('diagram-card');
            if (diagCard) {
                diagCard.classList.add('diag-visible');
                if (G) {
                    G.fromTo(diagCard,
                        { opacity: 0, x: 40, scale: 0.95 },
                        { opacity: 1, x: 0, scale: 1, duration: 0.8, ease: 'back.out(1.2)' }
                    );
                }
            }
        }

        /* ── Diagram Intelligence Upgrade ─────────────────────── */
        if (t === 'diagram_zoom_in') {
            if (d && d.region) {
                if (typeof zoomToRegion === 'function') zoomToRegion(d.region, d.zoom_scale || 2.2, 0.9);
                if (typeof moveCursor === 'function') moveCursor(d.region);
            }
        }

        if (t === 'diagram_zoom_out') {
            if (typeof zoomOut === 'function') zoomOut(0.85);
        }

        if (t === 'diagram_annotate_circle') {
            if (d && d.region) {
                if (typeof drawCircleAnnotation === 'function') drawCircleAnnotation(d.region, d.annotation_color || '#00E5FF');
            }
        }

        if (t === 'diagram_highlight_region') {
            if (d && d.region) {
                if (typeof drawHighlightBox === 'function') drawHighlightBox(d.region, d.annotation_color || '#FF4444');
            }
        }

        if (t === 'diagram_flow_arrow') {
            if (d && d.from_region && d.to_region) {
                if (typeof drawFlowArrow === 'function') drawFlowArrow(d.from_region, d.to_region, d.label || '', '#FFD700');
            }
        }

        if (t === 'diagram_cursor_move') {
            if (d && d.region) {
                if (typeof moveCursor === 'function') moveCursor(d.region);
            }
        }

        if (t === 'diagram_overview') {
            let curDot = document.getElementById('cursor-dot');
            if (curDot && G) {
                G.to(curDot, { opacity:1, left:'50%', top:'50%', duration:0.5 });
            }
        }
        /* ─────────────────────────────────────────────────────── */

        /* ── annotation_circle: DNA-2/5 Vector chalk circle ── */
        if (t === 'annotation_circle') {
            const svg = $('diagram-svg-overlay') || $('teacher-draw-svg');
            const img = $('diagram-img');
            if (svg && d.bbox) {
                const iw = img ? img.offsetWidth : svg.clientWidth || 800;
                const ih = img ? img.offsetHeight : svg.clientHeight || 600;
                const [bx, by, bw, bh] = d.bbox;
                
                const cx = (bx + bw/2) * iw;
                const cy = (by + bh/2) * ih;
                const rx = (bw/2) * iw + 15;
                const ry = (bh/2) * ih + 15;
                
                const ell = document.createElementNS('http://www.w3.org/2000/svg', 'ellipse');
                ell.setAttribute('cx', cx);
                ell.setAttribute('cy', cy);
                ell.setAttribute('rx', rx);
                ell.setAttribute('ry', ry);
                ell.setAttribute('fill', 'none');
                ell.setAttribute('stroke', d.color || '#00E5FF');
                ell.setAttribute('stroke-width', '4');
                ell.setAttribute('filter', 'url(#glow)');
                
                const len = 2 * Math.PI * Math.sqrt((rx*rx + ry*ry)/2) + 50;
                ell.style.strokeDasharray = len;
                ell.style.strokeDashoffset = len;
                
                svg.appendChild(ell);
                
                if (G) {
                    G.to(ell, {
                        strokeDashoffset: 0,
                        duration: 1.0,
                        ease: 'power2.out'
                    });
                    setTimeout(() => {
                        G.to(ell, { opacity: 0, duration: 0.5, onComplete: () => { try { svg.removeChild(ell); } catch(e) {} } });
                    }, durMs || 2500);
                } else {
                    ell.style.strokeDashoffset = '0';
                    setTimeout(() => { try { svg.removeChild(ell); } catch(e) {} }, 2500);
                }
            }
        }

        /* ── flow_arrow_draw / arrow_draw: DNA-2/3 flow vector transition ── */
        if (t === 'flow_arrow_draw' || t === 'arrow_draw') {
            const svg = $('diagram-svg-overlay') || $('teacher-draw-svg');
            const img = $('diagram-img');
            const localArrowPath = $('arrow-path');
            if (localArrowPath) {
                // DNA-3 native arrow element shortcut
                localArrowPath.style.strokeDashoffset = '0';
            }
            if (svg && d.from_bbox && d.to_bbox) {
                const dw = img ? img.offsetWidth : svg.clientWidth || 800;
                const dh = img ? img.offsetHeight : svg.clientHeight || 600;
                
                const fb = d.from_bbox;
                const tb = d.to_bbox;
                
                const x1 = (fb[0] + fb[2]/2) * dw;
                const y1 = (fb[1] + fb[3]/2) * dh;
                const x2 = (tb[0] + tb[2]/2) * dw;
                const y2 = (tb[1] + tb[3]/2) * dh;
                
                const arrow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                const cpx = (x1 + x2) / 2;
                const pathData = `M${x1},${y1} C${cpx},${y1} ${cpx},${y2} ${x2},${y2}`;
                arrow.setAttribute('d', pathData);
                arrow.setAttribute('stroke', d.color || '#FFD700');
                arrow.setAttribute('stroke-width', '4');
                arrow.setAttribute('fill', 'none');
                arrow.setAttribute('marker-end', 'url(#arrowhead)');
                
                const len = Math.sqrt(Math.pow(x2-x1, 2) + Math.pow(y2-y1, 2)) * 1.2 + 50;
                arrow.style.strokeDasharray = len;
                arrow.style.strokeDashoffset = len;
                arrow.style.transition = 'stroke-dashoffset 0.8s ease';
                
                svg.appendChild(arrow);
                requestAnimationFrame(() => { arrow.style.strokeDashoffset = '0'; });
                setTimeout(() => { if (svg.contains(arrow)) svg.removeChild(arrow); }, durMs || 2500);
            }
        }

        /* ── cause_highlight: DNA-3 Highlight left side ── */
        if (t === 'cause_highlight') {
            const cause = $('cause-panel-target');
            if (cause) {
                cause.classList.add('active');
                if (G) {
                    G.fromTo(cause, 
                        { boxShadow: '0 0 10px rgba(255, 59, 59, 0.2)' },
                        { boxShadow: '0 0 45px rgba(255, 59, 59, 0.65)', duration: 0.6, yoyo: true, repeat: 1, ease: 'sine.inOut' }
                    );
                }
            }
        }

        /* ── effect_highlight: DNA-3 Highlight right side ── */
        if (t === 'effect_highlight') {
            const effect = $('effect-panel-target');
            if (effect) {
                effect.classList.add('active');
                if (G) {
                    G.fromTo(effect, 
                        { boxShadow: '0 0 10px rgba(16, 185, 129, 0.2)' },
                        { boxShadow: '0 0 45px rgba(16, 185, 129, 0.65)', duration: 0.6, yoyo: true, repeat: 1, ease: 'sine.inOut' }
                    );
                }
            }
        }

        /* ── column_a_slide_in / column_b_slide_in: DNA-4 tabular slide ── */
        if (t === 'column_a_slide_in') {
            const cols = qa('.column-a');
            const header = $('col-header-a');
            if (header) header.classList.add('visible');
            if (cols.length > 0) {
                if (G) {
                    G.to(cols, { opacity: 1, x: 0, duration: 0.8, stagger: 0.08, ease: 'power3.out' });
                } else {
                    cols.forEach(c => c.classList.add('visible'));
                }
            }
        }
        if (t === 'column_b_slide_in') {
            const cols = qa('.column-b');
            const header = $('col-header-b');
            if (header) header.classList.add('visible');
            if (cols.length > 0) {
                if (G) {
                    G.to(cols, { opacity: 1, x: 0, duration: 0.8, stagger: 0.08, ease: 'power3.out' });
                } else {
                    cols.forEach(c => c.classList.add('visible'));
                }
            }
        }

        /* ── difference_cell_flash: DNA-4 compare flash ── */
        if (t === 'difference_cell_flash') {
            const rIdx = d.row_index;
            const row = $('row_' + rIdx) || q(`.table-row[data-row="${rIdx}"]`);
            if (row) {
                const cells = row.querySelectorAll('.table-cell-val');
                if (cells.length > 0) {
                    if (G) {
                        G.fromTo(cells, 
                            { backgroundColor: 'rgba(255, 215, 0, 0.45)' },
                            { backgroundColor: 'transparent', duration: 1.2, ease: 'power2.out' }
                        );
                    } else {
                        cells.forEach(c => {
                            c.style.backgroundColor = 'rgba(255, 215, 0, 0.45)';
                            setTimeout(() => { c.style.backgroundColor = ''; }, 1200);
                        });
                    }
                }
            }
        }

        /* ── formula_render: DNA-6 worked example KaTeX entry ── */
        if (t === 'formula_render') {
            const target = $('katex-target');
            if (target) {
                if (G) {
                    G.fromTo(target, 
                        { opacity: 0, scale: 0.85 }, 
                        { opacity: 1, scale: 1, duration: 1.0, ease: 'expo.out' }
                    );
                } else {
                    target.style.opacity = '1';
                }
            }
        }

        /* ── term_underline_draw: DNA-6 math step underline ── */
        if (t === 'term_underline_draw') {
            const stepIdx = d.step_index;
            const latexStr = d.latex || '';
            const katexTarget = $('katex-target');
            let targetEl = null;
            if (katexTarget) {
                const spans = katexTarget.querySelectorAll('.katex-html span');
                const cleanLatex = latexStr.replace(/[^a-zA-Z0-9\+\-\*=]/g, '');
                for (let span of spans) {
                    const sText = span.textContent.trim().replace(/[^a-zA-Z0-9\+\-\*=]/g, '');
                    if (sText && cleanLatex && (sText === cleanLatex || sText.includes(cleanLatex))) {
                        targetEl = span;
                        break;
                    }
                }
                if (!targetEl) {
                    targetEl = $('bullet_' + stepIdx) || q(`.legend-card[data-index="${stepIdx}"]`);
                }
            }
            if (targetEl) {
                const legendCard = $('bullet_' + stepIdx) || q(`.legend-card[data-index="${stepIdx}"]`);
                if (legendCard) {
                    legendCard.classList.add('visible');
                    if (G) {
                        G.fromTo(legendCard, { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.5 });
                    }
                }
                
                const svg = $('diagram-svg-overlay');
                const underline = $('term-underline');
                if (svg && underline && targetEl) {
                    const rect = targetEl.getBoundingClientRect();
                    const sRect = svg.getBoundingClientRect();
                    const x1 = rect.left - sRect.left;
                    const x2 = rect.right - sRect.left;
                    const y = rect.bottom - sRect.top + 4;
                    
                    const dPath = `M ${x1} ${y} Q ${(x1+x2)/2} ${y+3} ${x2} ${y}`;
                    underline.setAttribute('d', dPath);
                    underline.setAttribute('stroke', d.color || '#FFD700');
                    underline.style.opacity = '1';
                    
                    const len = x2 - x1;
                    underline.style.strokeDasharray = len;
                    underline.style.strokeDashoffset = len;
                    
                    if (G) {
                        G.killTweensOf(underline);
                        G.fromTo(underline, 
                            { strokeDashoffset: len }, 
                            { strokeDashoffset: 0, duration: 0.6, ease: 'power2.out' }
                        );
                    } else {
                        underline.style.strokeDashoffset = '0';
                    }
                }
            }
        }

        /* ── term_zoom: DNA-6 camera zoom focus on math term ── */
        if (t === 'term_zoom') {
            const stepIdx = d.step_index;
            const vp = $('diagram-viewport');
            const katexTarget = $('katex-target');
            let targetEl = null;
            if (katexTarget) {
                const spans = katexTarget.querySelectorAll('.katex-html span');
                if (spans.length > 0) {
                    targetEl = spans[Math.min(stepIdx, spans.length - 1)];
                }
            }
            if (vp && G) {
                const scale = d.scale || 1.8;
                let tx = 0, ty = 0;
                if (targetEl && katexTarget) {
                    const rect = targetEl.getBoundingClientRect();
                    const vRect = vp.getBoundingClientRect();
                    const cx = (rect.left + rect.right) / 2;
                    const cy = (rect.top + rect.bottom) / 2;
                    const vcx = (vRect.left + vRect.right) / 2;
                    const vcy = (vRect.top + vRect.bottom) / 2;
                    tx = (vcx - cx) * (scale - 1);
                    ty = (vcy - cy) * (scale - 1);
                    
                    const maxTx = 100 * scale;
                    const maxTy = 50 * scale;
                    tx = Math.max(-maxTx, Math.min(maxTx, tx));
                    ty = Math.max(-maxTy, Math.min(maxTy, ty));
                }
                G.to(vp, {
                    scale: scale, x: tx, y: ty,
                    transformOrigin: '50% 50%',
                    duration: 1.0, ease: 'power3.inOut'
                });
                setTimeout(() => {
                    G.to(vp, { scale: 1.0, x: 0, y: 0, duration: 0.8, ease: 'power2.inOut' });
                    const underline = $('term-underline');
                    if (underline) G.to(underline, { opacity: 0, duration: 0.5 });
                }, 2500);
            }
        }

        /* ── analogy_panel_glow: DNA-7 metaphor highlight ── */
        if (t === 'analogy_panel_glow') {
            const panel = $('analogy-panel-target');
            if (panel && G) {
                G.fromTo(panel, 
                    { backgroundColor: 'rgba(255, 255, 255, 0.02)' },
                    { backgroundColor: 'rgba(212, 168, 83, 0.06)', duration: 1.0, yoyo: true, repeat: 1, ease: 'power2.inOut' }
                );
            }
        }

        /* ── bridge_arrow_draw: DNA-7 metaphor climax bridge ── */
        if (t === 'bridge_arrow_draw') {
            const bridgePath = $('bridge-path');
            if (bridgePath) {
                bridgePath.style.strokeDashoffset = '0';
            }
        }

        /* ── concept_panel_reveal: DNA-7 reveal principle ── */
        if (t === 'concept_panel_reveal') {
            const panel = $('concept-panel-target');
            if (panel) {
                panel.classList.add('reveal-active');
                if (G) {
                    G.fromTo(panel, 
                        { y: 30, opacity: 0 },
                        { y: 0, opacity: 1, duration: 1.0, ease: 'power4.out' }
                    );
                }
            }
        }

        /* ── background_transition: DNA-8 dark fullscreen ── */
        if (t === 'background_transition') {
            const stage = $('summary-stage');
            if (stage) {
                const bgCol = d.color || '#0C1223';
                if (G) {
                    G.to(stage, { backgroundColor: bgCol, duration: 1.0, ease: 'power2.inOut' });
                } else {
                    stage.style.backgroundColor = bgCol;
                }
            }
        }

        /* ── avatar_scale_to_center: DNA-8 summary avatar center focus ── */
        if (t === 'avatar_scale_to_center') {
            const avatar = $('avatar');
            const avatarRing = $('avatar-ring');
            const avHidden = avatar && getComputedStyle(avatar).display === 'none';
            if (avatar && G && !avHidden) {
                const scale = d.scale || 1.5;
                const w = window.innerWidth;
                const h = window.innerHeight;
                const targetW = 160 * scale;
                const targetH = 160 * scale;
                const targetLeft = (w - targetW) / 2;
                const targetBottom = 100;
                
                G.killTweensOf(avatar);
                G.to(avatar, {
                    left: targetLeft,
                    bottom: targetBottom,
                    width: targetW,
                    height: targetH,
                    scale: 1,
                    duration: 1.2,
                    ease: 'power3.out',
                    boxShadow: '0 0 40px 15px rgba(212, 168, 83, 0.4)'
                });
                if (avatarRing) {
                    G.killTweensOf(avatarRing);
                    G.to(avatarRing, {
                        left: targetLeft - 9,
                        bottom: targetBottom - 9,
                        width: targetW + 18,
                        height: targetH + 18,
                        opacity: 0.6,
                        duration: 1.2,
                        ease: 'power3.out'
                    });
                }
            }
        }

        /* ── gold_text_fade_in: DNA-8 key summary text ── */
        if (t === 'gold_text_fade_in') {
            const heading = $('summary-heading');
            const desc = $('summary-desc');
            if (heading) heading.classList.add('visible');
            if (desc) desc.classList.add('visible');
            if (G) {
                if (heading) G.to(heading, { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.5)' });
                if (desc) G.to(desc, { opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: 'power3.out' });
            }
        }

        /* ── avatar_return_to_corner: DNA-8 summary avatar return ── */
        if (t === 'avatar_return_to_corner') {
            const avatar = $('avatar');
            const avatarRing = $('avatar-ring');
            const avHidden2 = avatar && getComputedStyle(avatar).display === 'none';
            if (avatar && G && !avHidden2) {
                G.killTweensOf(avatar);
                G.to(avatar, {
                    left: 28,
                    bottom: 28,
                    width: 160,
                    height: 160,
                    scale: 1,
                    duration: 1.0,
                    ease: 'power3.inOut',
                    boxShadow: '0 0 12px 4px rgba(74,144,217,0.4)'
                });
                if (avatarRing) {
                    G.killTweensOf(avatarRing);
                    G.to(avatarRing, {
                        left: 19,
                        bottom: 19,
                        width: 178,
                        height: 178,
                        opacity: 0.5,
                        duration: 1.0,
                        ease: 'power3.inOut'
                    });
                }
            }
        }

        /* ── heading_action: GSAP smooth entrance ─────── */
        if (t === 'heading_focus') {
