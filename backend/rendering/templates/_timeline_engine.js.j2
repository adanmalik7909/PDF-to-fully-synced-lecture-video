                        } else if (d.annotation_type === 'highlight_box') {
                            let hBox = $('spatial-highlight');
                            if (!hBox) {
                                hBox = document.createElement('div');
                                hBox.id = 'spatial-highlight';
                                hBox.className = 'spatial-highlight-box';
                                hBox.style.position = 'absolute';
                                hBox.style.pointerEvents = 'none';
                                vp.appendChild(hBox);
                            }
                            if (img) {
                                const iw = img.offsetWidth || 800;
                                const ih = img.offsetHeight || 600;
                                const imgL = img.offsetLeft || ((vpW - iw) / 2);
                                const imgT = img.offsetTop || ((vpH - ih) / 2);

                                hBox.style.left = (imgL + r.x_pct * iw) + 'px';
                                hBox.style.top = (imgT + r.y_pct * ih) + 'px';
                                hBox.style.width = (r.w_pct * iw) + 'px';
                                hBox.style.height = (r.h_pct * ih) + 'px';
                            }
                            G.killTweensOf(hBox);
                            G.fromTo(hBox, {opacity: 0, scale: 0.8}, {opacity: 1, scale: 1, duration: 0.5, ease: 'back.out(1.5)'});
                        }
                    }
                } else {
                    G.to(vp, {scale: 1.25, transformOrigin: "center center", duration: 1.1, ease: "power3.inOut"});
                }
                
                if (img) {
                    G.to(img, {boxShadow: "0 0 18px 4px rgba(0, 229, 255, 0.5)", yoyo: true, repeat: 2, duration: 0.6, delay: 0.4});
                }
            }
        }

        /* ── UPGRADE B: diagram_cursor_move ──────────────── */
        if (t === 'diagram_cursor_move') {
            const img = $('diagram-img');
            const stage = $('diag-stage') || $('diagram-card') || $('right-panel');
            if (stage && G && d.region) {
                // Ensure cursor dot exists
                let cursor = $('cursor-dot');
                if (!cursor) {
                    cursor = document.createElement('div');
                    cursor.id = 'cursor-dot';
                    cursor.style.position = 'absolute';
                    cursor.style.width = '18px';
                    cursor.style.height = '18px';
                    cursor.style.zIndex = '200';
                    cursor.style.background = 'rgba(0, 229, 255, 0.9)';
                    cursor.style.boxShadow = '0 0 12px 6px rgba(0, 229, 255, 0.5)';
                    cursor.style.borderRadius = '50%';
                    cursor.style.pointerEvents = 'none';
                    cursor.style.opacity = '0';
                    cursor.style.transform = 'translate(-50%, -50%)';
                    stage.appendChild(cursor);
                }

                const r = d.region;
                const cx = r.x_pct + r.w_pct / 2;
                const cy = r.y_pct + r.h_pct / 2;

                const stageRect = stage.getBoundingClientRect();
                let targetX = stageRect.width / 2;
                let targetY = stageRect.height / 2;

                if (img) {
                    const imgRect = img.getBoundingClientRect();
                    const sRect = stage.getBoundingClientRect();
                    targetX = (imgRect.left - sRect.left) + cx * imgRect.width;
                    targetY = (imgRect.top - sRect.top) + cy * imgRect.height;
                }

                // If first move or hidden, jump to start
                const isFirstMove = window.cursorFirstMove !== false;
                window.cursorFirstMove = false;

                if (isFirstMove || parseFloat(cursor.style.opacity) === 0) {
                    G.set(cursor, { opacity: 0.8, x: targetX, y: targetY });
                }

                // Move smoothly using GSAP
                G.to(cursor, {
                    x: targetX,
                    y: targetY,
                    opacity: 0.8,
                    duration: 0.8,
                    ease: "power2.inOut",
                    onComplete: () => {
                        // Ripple pulse scale
                        G.fromTo(cursor, 
                            { scale: 1, opacity: 0.8 }, 
                            { scale: 2.5, opacity: 0, duration: 0.5, ease: "power1.out",
                              onComplete: () => {
                                  G.set(cursor, { scale: 1, opacity: 0.8 });
                              }
                            }
                        );
                    }
                });
            }
        }

        /* ── UPGRADE 2: diagram_zoom_out ─────────────────── */
        if (t === 'diagram_zoom_out') {
            const vp = $('diagram-viewport') || $('diagram-zoom-target') || $('diagram-wrapper') || $('.diagram-zoom-wrapper');
            if (vp && G) {
                G.to(vp, {scale: 1.0, x: 0, y: 0, duration: 1.0, ease: "power2.inOut"});
                
                // Clear Fabric drawings
                if (window.fabricCanvas) {
