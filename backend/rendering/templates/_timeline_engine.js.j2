                    window.fabricCanvas.renderAll();
                }

                // Clear dynamic brain circles
                const bCircles = document.querySelectorAll('#diagram-brain-circle');
                bCircles.forEach(bc => {
                    G.to(bc, {opacity: 0, duration: 0.5, onComplete: () => { try { bc.remove(); } catch(e) {} }});
                });

                // Clear highlights
                const hBox = $('spatial-highlight');
                if (hBox) {
                    G.to(hBox, {opacity: 0, duration: 0.5});
                }

                // Hide cursor
                const cursor = $('cursor-dot');
                if (cursor) {
                    G.to(cursor, {opacity: 0, duration: 0.5});
                }
                window.cursorFirstMove = true;
            }
        }

        /* ── diagram_zoom: zoom into a specific region ─────── */
        if (t === 'diagram_zoom') {
            const img = $('diagram-img');
            if (img) {
                const scale = d.scale || 1.35;
                const ox = d.origin_x !== undefined ? d.origin_x * 100 : 50;
                const oy = d.origin_y !== undefined ? d.origin_y * 100 : 50;
                img.style.transformOrigin = ox + '% ' + oy + '%';
