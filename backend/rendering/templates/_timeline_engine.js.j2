/* ═══════════════════════════════════════════════════════════════
   SmartStudyInstructor V12.5 — GSAP Hybrid Timeline Engine
   
   Reads TIMELINE_DATA from Python's TimelineBuilder.
   Uses GSAP 3.15 for professional spring/elastic animations
   while keeping requestAnimationFrame tick loop for event firing.
   
   SUBTITLE STRATEGY:
     FFmpeg burns SRT subtitles (synced with audio).
     
   Runs via requestAnimationFrame for frame-perfect Playwright capture.
═══════════════════════════════════════════════════════════════ */

(function () {
    'use strict';

    /* ─── Parse timeline data ──────────────────────────────── */
    const TD       = window.TIMELINE_DATA || {};
    const timeline = TD.events || [];
    const totalMs  = TD.total_duration_ms || 10000;

    const startTime  = performance.now();
    const firedFlags = new Array(timeline.length).fill(false);

    /* ─── Util ─────────────────────────────────────────────── */
    const $ = id => document.getElementById(id);
    const q = sel => document.querySelector(sel);
    const qa = sel => document.querySelectorAll(sel);
    const now = () => performance.now() - startTime;

    /* ─── GSAP availability check ──────────────────────────── */
    const G = typeof gsap !== 'undefined' ? gsap : null;

    /* ─── Fade scene in ────────────────────────────────────── */
    document.body.classList.add('scene-ready');

    /* ═══════════════════════════════════════════════════════════
       EVENT HANDLERS
       Each handler matches event_type from timeline_builder.py
    ═══════════════════════════════════════════════════════════ */

    function handleEvent(ev) {
        const t    = ev.event_type;
        const d    = ev.data || {};
        const durMs = ev.end_ms - ev.start_ms;

        /* ── scene_start: V13 dynamic avatar sizing ────────── */
        if (t === 'scene_start') {
            const avatar = $('avatar');
            const avatarRing = $('avatar-ring');
            if (avatar && avatarRing && G) {
                // UPGRADE 1 — AVATAR CINEMATIC ENTRY ANIMATION
                G.set([avatar, avatarRing], {
                    left: '50%', top: '50%', xPercent: -50, yPercent: -50,
                    opacity: 0, scale: 0.05
                });
                G.set(avatar, { width: 480, height: 480, filter: 'blur(20px)' });
                G.set(avatarRing, { width: 520, height: 520 });

                // 0 to 1100ms
                G.to(avatar, {
                    scale: 1, opacity: 1, filter: 'blur(0px)', duration: 1.1, ease: 'expo.out'
                });
                G.to(avatarRing, {
                    scale: 1.3, opacity: 0, duration: 0.8, ease: 'expo.out'
                });

                // 1800ms to 3000ms: transition to bottom-left corner
                G.to(avatar, {
                    left: 28, bottom: 28, top: 'auto', xPercent: 0, yPercent: 0,
                    width: 160, height: 160, duration: 1.2, delay: 1.8, ease: 'power4.inOut'
                });
                G.set(avatarRing, { scale: 1, delay: 1.8 }); 
                G.to(avatarRing, {
                    left: 19, bottom: 19, top: 'auto', xPercent: 0, yPercent: 0,
                    width: 178, height: 178, opacity: 0.5, duration: 1.2, delay: 1.8, ease: 'power4.inOut',
                    onComplete: () => {
                        // 3000ms onward: soft breathing glow
                        G.fromTo(avatar, 
                            { boxShadow: "0 0 12px 4px rgba(74,144,217,0.4)" },
                            { boxShadow: "0 0 28px 10px rgba(74,144,217,0.85)", duration: 2.2, ease: "sine.inOut", yoyo: true, repeat: -1 }
                        );
                    }
                });
            }
        }
        
        /* ── scene_end: White flash ────────── */
        if (t === 'scene_end') {
            const flash = $('scene-flash');
            if (flash && G) {
                G.fromTo(flash, {opacity: 0}, {opacity: 1, duration: 0.3, yoyo: true, repeat: 1});
            }
        }

        /* ── heading_action: GSAP smooth entrance ─────── */
        if (t === 'heading_action' || t === 'heading_focus') {
            const el = $('heading-left') || q('.slide-heading');
            if (el) {
                if (G) {
                    // Smooth fade and slide up
                    G.fromTo(el, 
                        {opacity: 0, y: 30}, 
                        {opacity: 1, y: 0, duration: 0.8, ease: "power3.out", onComplete: () => {
                            // UPGRADE 4 — HEADING GOLD WORD GLOW ON ENTRY
                            const goldWord = el.querySelector('.gold-word');
                            if (goldWord) {
                                goldWord.style.display = 'inline-block';
                                G.to(goldWord, {
                                    color: '#FFD700', textShadow: "0 0 24px rgba(255,200,0,0.9)", 
                                    scale: 1.08, duration: 0.45, ease: "power2.inOut", yoyo: true, repeat: 1
                                });
                            }
                        }}
                    );
                }
            }
        }

        /* ── ken_burns: subtle camera motion on left panel ─── */
        if (t === 'ken_burns') {
            const kbEl = $('kb-target');
            if (kbEl) {
                const dir = (d.direction || 'pan_right').replace(/_/g, '-');
                kbEl.classList.remove('kb-pan-right','kb-pan-left','kb-zoom-in','kb-zoom-out');
                void kbEl.offsetWidth; // force reflow
                kbEl.classList.add('kb-' + dir);
            }
        }

        /* ── bullet_enter: GSAP slide from left ────────────── */
        if (t === 'bullet_enter') {
            const idx = d.index;
            if (idx === undefined) return;
            const el = $('bullet_' + idx) || q(`.bullet[data-index="${idx}"]`);
            if (el) {
                if (G) {
                    G.fromTo(el, {x:-30, opacity:0}, {x:0, opacity:1, duration:0.4, ease:'power3.out'});
                    el.classList.add('b-visible');
                    
                    // UPGRADE 3 — BULLET TEXT WORD-BY-WORD REVEAL
                    const wordSpans = el.querySelectorAll('.word-span');
                    if (wordSpans.length > 0) {
                        const wordEvents = timeline.filter(e => e.event_type === 'subtitle_word_hl' && e.start_ms >= ev.start_ms).sort((a,b) => a.start_ms - b.start_ms);
                        let eIdx = 0;
                        wordSpans.forEach(span => {
                            const txt = span.textContent.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
                            let matchedDelay = (ev.start_ms / 1000) + (eIdx * 0.1); // fallback
                            
                            for (let i = eIdx; i < wordEvents.length; i++) {
                                let eWord = wordEvents[i].data.word.toLowerCase().replace(/[^a-z0-9]/g, '');
                                if (eWord && (eWord === txt || txt.includes(eWord) || eWord.includes(txt))) {
                                    // Make relative delay for the animation timeline
                                    matchedDelay = (wordEvents[i].start_ms - ev.start_ms) / 1000;
                                    eIdx = i + 1;
                                    break;
                                }
                            }
                            
                            // Make sure spans behave inline-block so we can animate Y
                            span.style.display = 'inline-block';
                            G.fromTo(span, 
                                {opacity: 0, y: 12, filter: 'blur(4px)'}, 
                                {opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.35, ease: 'power2.out', delay: matchedDelay}
                            );
                        });
                    }
                } else {
                    el.classList.add('b-visible');
                }
            }
        }

        /* ── bullet_active: GSAP bounce highlight ──────────── */
        if (t === 'bullet_active') {
            const idx = d.index;
            if (idx === undefined) return;
            qa('.bullet').forEach((b, i) => {
                if (i < idx) {
                    b.classList.remove('b-active');
                    b.classList.add('b-done');
                }
            });
            const el = $('bullet_' + idx) || q(`.bullet[data-index="${idx}"]`);
            if (el) {
                el.classList.add('b-visible', 'b-active');
                if (G) {
                    const numEl = el.querySelector('.bullet-num, .step-card-num');
                    if (numEl) G.to(numEl, {backgroundColor:'#D4A853', color:'#1A2535', scale:1.1, duration:0.3, ease:'back.out(2)'});
                    const txtEl = el.querySelector('.bullet-text, .step-card-text');
                    if (txtEl) G.to(txtEl, {color:'#1C2B3A', fontWeight:'600', duration:0.3});
                }
            }
        }

        /* ── bullet_done: dim the bullet ───────────────────── */
        if (t === 'bullet_done') {
            const idx = d.index;
            if (idx === undefined) return;
            const el = $('bullet_' + idx) || q(`.bullet[data-index="${idx}"]`);
            if (el) {
                el.classList.remove('b-active');
                el.classList.add('b-done');
                if (G) G.to(el, {opacity:0.45, duration:0.3});
            }
        }

        /* ── zoom_word_glow: GSAP golden pulse ──────────────── */
        if (t === 'zoom_word_glow') {
            const elId = d.element_id;
            const el = elId ? $(elId) : null;
            if (el) {
                if (G) {
                    G.to(el, {scale:1.18, color:'#FFD700',
                      textShadow:'0 0 20px #FFD700, 0 0 40px rgba(255,215,0,0.4)',
                      duration:0.25, ease:'power2.out', yoyo:true, repeat:1});
                } else {
                    el.classList.add('zw-glowing');
                    setTimeout(() => el.classList.remove('zw-glowing'), durMs || 2000);
                }
            }
        }

        /* ── diagram_enter: slide diagram card into view ───── */
        if (t === 'diagram_enter') {
            const card = $('diagram-card');
            if (card) {
                card.classList.add('diag-visible');
                // Start subtle Ken Burns on diagram after entrance
                setTimeout(() => card.classList.add('diag-zoom'), 700);
            }
            // Move avatar out of the way
            const av = $('avatar');
            if (av && G) {
                G.to(av, {left: 28, bottom: 28, width: 120, height: 120, duration: 0.6, ease: 'power2.inOut'});
            }
        }

        /* ── UPGRADE 2: diagram_zoom_in & annotation ─────── */
        if (t === 'diagram_zoom_in') {
            const zoomTarget = $('diagram-zoom-target') || $('diagram-wrapper');
            const img = $('diagram-img');
            if (zoomTarget && G) {
                G.to(zoomTarget, {scale: 1.8, transformOrigin: "center center", duration: 1.1, ease: "power3.inOut"});
                
                const annLayer = $('annotation-layer');
                const annCircle = $('annotation-circle');
                const annArrow = $('annotation-arrow');
                if (annLayer && annCircle) {
                    G.to(annLayer, {opacity: 1, duration: 0.3, delay: 0.4});
                    // Use standard strokeDashoffset instead of DrawSVG plugin
                    try {
                        const circleLen = annCircle.getTotalLength ? annCircle.getTotalLength() : 600;
                        annCircle.style.strokeDasharray = circleLen;
                        annCircle.style.strokeDashoffset = circleLen;
                        G.to(annCircle, {strokeDashoffset: 0, duration: 1.4, delay: 0.4, ease: 'power2.inOut'});
                    } catch(e) { /* SVG percentage values may not support getTotalLength */ }
                    if (annArrow) {
                        try {
                            const arrowLen = annArrow.getTotalLength ? annArrow.getTotalLength() : 300;
                            annArrow.style.strokeDasharray = arrowLen;
                            annArrow.style.strokeDashoffset = arrowLen;
                            G.to(annArrow, {strokeDashoffset: 0, duration: 0.9, delay: 1.8, ease: 'power2.inOut'});
                        } catch(e) { /* fallback */ }
                    }
                }
                
                if (img) {
                    G.to(img, {boxShadow: "0 0 18px 4px rgba(74,143,224,0.5)", yoyo: true, repeat: 2, duration: 0.6, delay: 0.4});
                }
            }
        }

        /* ── UPGRADE 2: diagram_zoom_out ─────────────────── */
        if (t === 'diagram_zoom_out') {
            const zoomTarget = $('diagram-zoom-target') || $('diagram-wrapper');
            if (zoomTarget && G) {
                G.to(zoomTarget, {scale: 1.0, duration: 1.0, ease: "power2.inOut"});
                const annLayer = $('annotation-layer');
                if (annLayer) {
                    G.to(annLayer, {opacity: 0, duration: 1.0});
                }
            }
        }

        /* ── diagram_zoom: zoom into a specific region ─────── */
        if (t === 'diagram_zoom') {
            const img = $('diagram-img');
            if (img) {
                const scale = d.scale || 1.35;
                const ox = d.origin_x !== undefined ? d.origin_x * 100 : 50;
                const oy = d.origin_y !== undefined ? d.origin_y * 100 : 50;
                img.style.transformOrigin = ox + '% ' + oy + '%';
                img.style.transform = 'scale(' + scale + ')';
                setTimeout(() => {
                    img.style.transform = 'scale(1)';
                    img.style.transformOrigin = 'center center';
                }, durMs || 3000);
            }
        }

        /* ── V14: diagram_overview — smooth full-view reset ─── */
        if (t === 'diagram_overview') {
            const vp = $('diagram-viewport');
            if (vp) {
                if (G) G.to(vp, {scale:1, x:0, y:0, duration:1.0, ease:'power2.inOut'});
                else { vp.style.transition = 'transform 1.0s ease'; vp.style.transform = 'scale(1) translate(0,0)'; }
            }
            const hBox = $('spatial-highlight');
            if (hBox) { if (G) G.to(hBox, {opacity:0, duration:0.3}); else hBox.style.opacity = '0'; }
            const ptr = $('spatial-pointer');
            if (ptr) { if (G) G.to(ptr, {opacity:0, duration:0.3}); else ptr.style.display = 'none'; }
        }

        /* ── V14: diagram_pan_zoom — boundary-safe camera glide ─
           Coords format from VLM: [ymin, xmin, ymax, xmax] in 0-1000 range.
           We zoom #diagram-viewport (not img) so stage overflow:hidden
           clips any overflow — diagram NEVER leaves the screen. ─────── */
        if (t === 'diagram_pan_zoom') {
            const vp  = $('diagram-viewport');
            const img = $('diagram-img');
            const stage = $('diag-stage');
            if (!vp || !img) break_out: { break break_out; }
            if (vp && img && d.coords) {
                // VLM returns [ymin, xmin, ymax, xmax] in 0-1000 range
                const [ymin, xmin, ymax, xmax] = d.coords;
                // Normalize to 0-1
                const nx1 = xmin / 1000, ny1 = ymin / 1000;
                const nx2 = xmax / 1000, ny2 = ymax / 1000;
                const nw  = Math.max(nx2 - nx1, 0.05);
                const nh  = Math.max(ny2 - ny1, 0.05);
                const ncx = nx1 + nw / 2;  // 0-1 center x
                const ncy = ny1 + nh / 2;  // 0-1 center y

                // Compute a comfortable scale that shows the region well
                const scaleX = 0.80 / nw;
                const scaleY = 0.80 / nh;
                const scale  = Math.min(Math.max(Math.min(scaleX, scaleY), 1.3), 3.0);

                // Compute pan offset so the region center aligns with stage center
                // We shift viewport by -(ncx - 0.5)*imgW*(scale-1) etc.
                const vpW = vp.offsetWidth  || stage.offsetWidth  || 1800;
                const vpH = vp.offsetHeight || stage.offsetHeight || 780;

                // translateX: move so ncx is at 50% of viewport
                let tx = (0.5 - ncx) * vpW;
                let ty = (0.5 - ncy) * vpH;

                // Clamp so we never pan past the image edge (boundary safety)
                const maxTx = (vpW * (scale - 1)) / (2 * scale);
                const maxTy = (vpH * (scale - 1)) / (2 * scale);
                tx = Math.max(-maxTx, Math.min(maxTx, tx));
                ty = Math.max(-maxTy, Math.min(maxTy, ty));

                if (G) {
                    G.to(vp, {
                        scale: scale, x: tx, y: ty,
                        transformOrigin: '50% 50%',
                        duration: 1.0, ease: 'power2.inOut'
                    });
                } else {
                    vp.style.transition = 'transform 1.0s cubic-bezier(0.4,0,0.2,1)';
                    vp.style.transformOrigin = '50% 50%';
                    vp.style.transform = `scale(${scale}) translate(${tx/scale}px, ${ty/scale}px)`;
                }

                // Highlight box on the image itself
                let hBox = $('spatial-highlight');
                if (!hBox) {
                    hBox = document.createElement('div');
                    hBox.id = 'spatial-highlight';
                    hBox.className = 'spatial-highlight-box';
                    hBox.style.position = 'absolute';
                    hBox.style.pointerEvents = 'none';
                    vp.appendChild(hBox);
                }
                const imgR = img.getBoundingClientRect();
                const stgR = vp.getBoundingClientRect();
                // Position box relative to viewport
                hBox.style.left   = ((nx1 * imgR.width  + imgR.left - stgR.left) / scale) + 'px';
                hBox.style.top    = ((ny1 * imgR.height + imgR.top  - stgR.top)  / scale) + 'px';
                hBox.style.width  = (nw * imgR.width  / scale) + 'px';
                hBox.style.height = (nh * imgR.height / scale) + 'px';
                if (G) G.fromTo(hBox, {opacity:0}, {opacity:1, duration:0.4, delay:0.3});
                else   hBox.style.opacity = '1';

                // Spatial pointer (pulsing dot) at center of highlighted region
                const ptr = $('spatial-pointer');
                if (ptr) {
                    const pxInImg = (ncx * imgR.width  + imgR.left - stgR.left) / scale;
                    const pyInImg = (ncy * imgR.height + imgR.top  - stgR.top)  / scale;
                    ptr.style.left = pxInImg + 'px';
                    ptr.style.top  = pyInImg + 'px';
                    ptr.style.display = 'flex';
                    if (G) G.fromTo(ptr, {opacity:0, scale:0.5}, {opacity:1, scale:1, duration:0.4, delay:0.4, ease:'back.out(2)'});
                }

                // Auto zoom-out after duration
                setTimeout(() => {
                    if (G) { G.to(vp, {scale:1, x:0, y:0, duration:0.8, ease:'power2.inOut'}); }
                    else { vp.style.transform = 'scale(1) translate(0,0)'; }
                    if (G) G.to(hBox, {opacity:0, duration:0.3});
                    else hBox.style.opacity = '0';
                    if (ptr) {
                        if (G) G.to(ptr, {opacity:0, duration:0.3});
                        else ptr.style.display = 'none';
                    }
                }, durMs || 3500);
            }
        }

        /* ── V14: diagram_label_popup — floating label ───────── */
        if (t === 'diagram_label_popup') {
            if (d.coords && d.label) {
                const [ymin, xmin, ymax, xmax] = d.coords;
                const nx1 = xmin / 1000, ny1 = ymin / 1000;
                const nx2 = xmax / 1000;
                const nw  = nx2 - nx1;

                let popup = $('diagram-label-popup');
                if (!popup) {
                    popup = document.createElement('div');
                    popup.id = 'diagram-label-popup';
                    popup.className = 'diagram-label-popup';
                    const vp = $('diagram-viewport') || $('diag-stage');
                    if (vp) vp.appendChild(popup);
                }

                // Position: above the highlighted region, clamped to screen
                const leftPct = Math.min(Math.max((nx1 + nw/2) * 100 - 10, 5), 70);
                const topPct  = Math.max(ny1 * 100 - 6, 2);
                popup.style.left = leftPct + '%';
                popup.style.top  = topPct  + '%';
                popup.textContent = d.label;
                popup.style.display = 'block';

                requestAnimationFrame(() => popup.classList.add('popup-visible'));

                setTimeout(() => {
                    popup.classList.remove('popup-visible');
                    setTimeout(() => { popup.style.display = 'none'; }, 400);
                }, durMs || 2800);
            }
        }

        /* ── V14: diagram_zoom_out_smooth ────────────────────── */
        if (t === 'diagram_zoom_out_smooth') {
            const vp = $('diagram-viewport');
            if (vp) {
                if (G) G.to(vp, {scale:1, x:0, y:0, duration:0.8, ease:'power2.inOut'});
                else { vp.style.transition = 'transform 0.8s ease'; vp.style.transform = 'scale(1)'; }
            }
            const hBox = $('spatial-highlight');
            if (hBox) { if (G) G.to(hBox, {opacity:0, duration:0.3}); else hBox.style.opacity = '0'; }
            const ptr = $('spatial-pointer');
            if (ptr) { if (G) G.to(ptr, {opacity:0, duration:0.3}); else ptr.style.display = 'none'; }
            const popup = $('diagram-label-popup');
            if (popup) { popup.classList.remove('popup-visible'); setTimeout(()=>{popup.style.display='none';},400); }
        }

        /* ── V12: diagram_draw_arrow — animated SVG arrow between components ── */
        if (t === 'diagram_draw_arrow') {
            const svg = $('diagram-svg-overlay');
            const img = $('diagram-img');
            if (svg && img && d.from_coords && d.to_coords) {
                const iw = img.offsetWidth || 800;
                const ih = img.offsetHeight || 600;

                const fc = d.from_coords;
                const tc = d.to_coords;
                // Center of from component
                const x1 = ((fc[1] + fc[3]) / 20) * iw / 100;
                const y1 = ((fc[0] + fc[2]) / 20) * ih / 100;
                // Center of to component
                const x2 = ((tc[1] + tc[3]) / 20) * iw / 100;
                const y2 = ((tc[0] + tc[2]) / 20) * ih / 100;

                const arrow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                const cpx = (x1 + x2) / 2;
                const pathData = 'M' + x1 + ',' + y1 + ' C' + cpx + ',' + y1 + ' ' + cpx + ',' + y2 + ' ' + x2 + ',' + y2;
                arrow.setAttribute('d', pathData);
                arrow.setAttribute('stroke', '#C9B99A');
                arrow.setAttribute('stroke-width', '3');
                arrow.setAttribute('fill', 'none');
                arrow.setAttribute('marker-end', 'url(#arrowhead)');
                arrow.style.strokeDasharray = '300';
                arrow.style.strokeDashoffset = '300';
                arrow.style.transition = 'stroke-dashoffset 0.8s ease';
                svg.appendChild(arrow);
                requestAnimationFrame(() => { arrow.style.strokeDashoffset = '0'; });
                setTimeout(() => { if (svg.contains(arrow)) svg.removeChild(arrow); }, durMs || 2000);
            }
        }

        /* ── V14: highlight_and_zoom — boundary-safe legacy alias ── */
        if (t === 'highlight_and_zoom') {
            // Reuse the diagram_pan_zoom logic via same handler
            if (d.coords) {
                handleEvent({...ev, event_type:'diagram_pan_zoom'});
            }
        }


        /* ── V11 Spatial Intelligence & UI Actions ─────────── */
        if (t === 'spatial_zoom_to_component') {
            const vp  = $('diagram-viewport');
            const img = $('diagram-img');
            if (vp && img && d.bbox) {
                const [bx, by, bw, bh] = d.bbox; // normalized 0-1
                const scale = Math.min(d.zoom_level || 1.8, 3.0);
                const vpW = vp.offsetWidth  || 1800;
                const vpH = vp.offsetHeight || 780;
                // Pan so the region center aligns with viewport center
                let tx = (0.5 - (bx + bw/2)) * vpW;
                let ty = (0.5 - (by + bh/2)) * vpH;
                // Clamp
                const maxTx = (vpW * (scale-1)) / (2*scale);
                const maxTy = (vpH * (scale-1)) / (2*scale);
                tx = Math.max(-maxTx, Math.min(maxTx, tx));
                ty = Math.max(-maxTy, Math.min(maxTy, ty));
                if (G) {
                    G.to(vp, {scale, x:tx, y:ty, transformOrigin:'50% 50%', duration:0.7, ease:'power2.inOut'});
                } else {
                    vp.style.transition = 'transform 0.7s ease';
                    vp.style.transform = `scale(${scale}) translate(${tx/scale}px,${ty/scale}px)`;
                }
                setTimeout(() => {
                    if (G) G.to(vp, {scale:1, x:0, y:0, duration:0.6, ease:'power2.inOut'});
                    else { vp.style.transform = 'scale(1)'; }
                }, (d.duration_ms || 2500) - 500);
            }
        }

        if (t === 'spatial_pointer_to') {
            let ptr = document.getElementById('spatial-pointer');
            if (ptr && d.bbox) {
                const [px, py, pw, ph] = d.bbox;
                const dw = document.getElementById('diagram-wrapper').offsetWidth;
                const dh = document.getElementById('diagram-wrapper').offsetHeight;
                ptr.style.left = ((px + pw / 2) * dw) + 'px';
                ptr.style.top  = ((py + ph / 2) * dh) + 'px';
                ptr.querySelector('.ptr-label').textContent = d.label || '';
                ptr.style.display = 'flex';
                ptr.style.opacity = '1';
                setTimeout(() => { ptr.style.opacity = '0'; }, d.duration_ms);
            }
        }

        if (t === 'spatial_highlight_region') {
            const canvas = document.getElementById('diagram-canvas-overlay');
            if (canvas && d.bbox) {
                const ctx = canvas.getContext('2d');
                const [hx, hy, hw, hh] = d.bbox;
                const cw = canvas.width, ch = canvas.height;
                ctx.clearRect(0, 0, cw, ch);
                ctx.fillStyle = 'rgba(0,0,0,0.45)';
                ctx.fillRect(0, 0, cw, ch);
                ctx.clearRect(hx * cw, hy * ch, hw * cw, hh * ch);
                ctx.strokeStyle = d.highlight_color || '#C9B99A';
                ctx.lineWidth = 3;
                ctx.strokeRect(hx * cw, hy * ch, hw * cw, hh * ch);
                setTimeout(() => ctx.clearRect(0, 0, cw, ch), d.duration_ms);
            }
        }

        if (t === 'spatial_draw_arrow') {
            const svg = document.getElementById('diagram-svg-overlay');
            if (svg && d.from_bbox && d.to_bbox) {
                const fromBbox = d.from_bbox;
                const toBbox = d.to_bbox;
                const dw = document.getElementById('diagram-wrapper').offsetWidth;
                const dh = document.getElementById('diagram-wrapper').offsetHeight;
                const x1 = (fromBbox[0] + fromBbox[2]) * dw;
                const y1 = (fromBbox[1] + fromBbox[3] / 2) * dh;
                const x2 = toBbox[0] * dw;
                const y2 = (toBbox[1] + toBbox[3] / 2) * dh;
                const arrow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                const pathData = `M${x1},${y1} C${(x1+x2)/2},${y1} ${(x1+x2)/2},${y2} ${x2},${y2}`;
                arrow.setAttribute('d', pathData);
                arrow.setAttribute('stroke', '#4F8EF7');
                arrow.setAttribute('stroke-width', '3');
                arrow.setAttribute('fill', 'none');
                arrow.setAttribute('marker-end', 'url(#arrowhead)');
                const length = 200; // approximation if getTotalLength isn't immediately available
                arrow.style.strokeDasharray = length;
                arrow.style.strokeDashoffset = length;
                arrow.style.transition = 'stroke-dashoffset 0.8s ease';
                svg.appendChild(arrow);
                requestAnimationFrame(() => { arrow.style.strokeDashoffset = '0'; });
                setTimeout(() => svg.removeChild(arrow), d.duration_ms);
            }
        }

        if (t === 'spatial_zoom_out') {
            const wrap = document.getElementById('diagram-wrapper');
            if (wrap) {
                wrap.style.transition = 'transform 0.4s ease';
                wrap.style.transform = 'scale(1)';
                wrap.style.transformOrigin = 'center center';
            }
            const canvas = document.getElementById('diagram-canvas-overlay');
            if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
            const ptr = document.getElementById('spatial-pointer');
            if (ptr) ptr.style.opacity = '0';
        }

        if (t === 'spatial_table_row_highlight') {
            document.querySelectorAll('.tbl-row').forEach(r => r.classList.remove('tbl-row-active'));
            const row = document.querySelector(`.tbl-row[data-row="${d.row_index}"]`);
            if (row) {
                row.classList.add('tbl-row-active');
                setTimeout(() => row.classList.remove('tbl-row-active'), d.duration_ms);
            }
        }

        /* heading_action with specific action_type — only handle zoom/underline sub-types
           (the basic heading_action entrance is already handled above at line ~97) */
        if (t === 'heading_action' && d.action_type) {
            const target = d.target || 'heading_right';
            const el = document.querySelector('.' + target.replace('_', '-')) || document.getElementById(target.replace('_', '-'));
            if (el) {
                if (d.action_type === 'heading_zoom') {
                    if (G) {
                        G.to(el, {scale:d.zoom_level||1.08, color:'#D4A853',
                          textShadow:'0 0 20px rgba(212,168,83,0.5)',
                          duration:0.4, ease:'elastic.out(1, 0.5)',
                          yoyo:true, repeat:1, repeatDelay:Math.max((durMs/1000)-0.8, 0.3)});
                    } else {
                        el.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
                        el.style.transform = 'scale(' + (d.zoom_level||1.08) + ')';
                        el.style.color = '#D4A853';
                        setTimeout(() => { el.style.transform='scale(1)'; el.style.color=''; }, durMs||1500);
                    }
                } else if (d.action_type === 'heading_underline') {
                    el.classList.add('heading-underline-anim');
                    setTimeout(() => el.classList.remove('heading-underline-anim'), durMs || 1500);
                }
            }
        }

        if (t === 'attention_hook') {
            let hook = document.getElementById('attention-hook-box');
            if (!hook) {
                hook = document.createElement('div');
                hook.id = 'attention-hook-box';
                document.body.appendChild(hook);
            }
            const icons = {'did_you_know':'💡','quick_recap':'🔄','warning_box':'⚠️','callout_bubble':'📌'};
            hook.className = 'hook-' + (d.hook_type||'did_you_know') + ' hook-' + (d.position||'top-right');
            hook.innerHTML = '<span class="hook-icon">' + (icons[d.hook_type]||'💡') + '</span><span class="hook-text">' + (d.text||'') + '</span>';
            hook.style.display = 'flex';
            if (G) {
                G.fromTo(hook, {opacity:0,y:-20,scale:0.8}, {opacity:1,y:0,scale:1,duration:0.4,ease:'back.out(1.5)'});
                G.to(hook, {opacity:0,y:10,duration:0.4,delay:3.0,onComplete:()=>{hook.style.display='none';}});
            } else {
                hook.style.opacity = '0';
                requestAnimationFrame(() => { hook.style.opacity = '1'; });
                setTimeout(() => { hook.style.opacity='0'; setTimeout(()=>{hook.style.display='none';},400); }, 3500);
            }
        }

        /* ── diagram_exit: hide diagram card ───────────────── */
        if (t === 'diagram_exit') {
            const card = $('diagram-card');
            if (card) card.classList.remove('diag-visible', 'diag-zoom');
            
            // Return avatar to default corner position
            const av = $('avatar');
            if (av && G) {
                G.to(av, {left: 28, bottom: 28, width: 160, height: 160, duration: 0.6, ease: 'power2.inOut'});
            }
        }

        /* ── takeaway_show: slide up takeaway bar ──────────── */
        if (t === 'takeaway_show') {
            const el = $('takeaway-bar');
            if (el) {
                if (G) G.fromTo(el, {y:'100%',opacity:0}, {y:'0%',opacity:1,duration:0.5,ease:'power3.out'});
                el.classList.add('takeaway-visible');
            }
        }

        /* ── analogy_overlay ───────────────────────────────── */
        if (t === 'analogy_overlay') {
            const ov = $('analogy-overlay');
            if (ov) {
                ov.style.background = 'linear-gradient(135deg, rgba(74,143,224,0.15), rgba(212,168,83,0.15))';
                ov.classList.add('analogy-visible');
                setTimeout(() => ov.classList.remove('analogy-visible'), durMs || 3000);
            }
        }

        /* ── scene_end: gentle fade (handled by flash above) ─ */
        /* NOTE: Body fade-out removed — it was making the entire
           scene invisible before Playwright could capture the final
           frames. The white flash at line 89 handles the transition. */

        /* ── subtitle_show / subtitle_word_hl ──────────────── */
        // Subtitles are handled by FFmpeg SRT burn (synced with audio).

        /* ═══════════════════════════════════════════════════════
           V12.5 — TEACHER DRAW ACTIONS (GSAP-powered)
        ═══════════════════════════════════════════════════════ */

        /* ── teacher_underline: V13 chalk-wobble polyline ──── */
        if (t === 'teacher_underline') {
            const svg = $('teacher-draw-svg');
            const tgt = d.target_selector ? q(d.target_selector) : null;
            if (svg && tgt && G) {
                const rect = tgt.getBoundingClientRect();
                const sRect = svg.getBoundingClientRect();
                const baseY = rect.bottom - sRect.top + 4;
                const x1 = rect.left - sRect.left;
                const x2 = rect.right - sRect.left;
                // Generate wobbly points (chalk effect)
                let points = '';
                const step = 15;
                for (let x = x1; x <= x2; x += step) {
                    const yOff = (Math.random() - 0.5) * 4; // ±2px wobble
                    points += x + ',' + (baseY + yOff) + ' ';
                }
                points += x2 + ',' + baseY;
                const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
                poly.setAttribute('points', points);
                poly.setAttribute('fill', 'none');
                poly.setAttribute('stroke', d.color || '#C9B99A');
                poly.setAttribute('stroke-width', '3');
                poly.setAttribute('stroke-linecap', 'round');
                poly.setAttribute('stroke-linejoin', 'round');
                poly.setAttribute('opacity', '0.85');
                const len = poly.getTotalLength ? poly.getTotalLength() : (x2 - x1);
                poly.style.strokeDasharray = len;
                poly.style.strokeDashoffset = len;
                svg.appendChild(poly);
                G.to(poly, {strokeDashoffset:0, duration:d.draw_duration_sec||0.6, ease:'power2.inOut'});
                setTimeout(() => {
                    G.to(poly, {opacity:0, duration:0.3, onComplete:() => { try{svg.removeChild(poly);}catch(e){} }});
                }, durMs - 300);
            }
        }

        /* ── teacher_circle: V13 organic chalk circle ──────── */
        if (t === 'teacher_circle') {
            const svg = $('diagram-svg-overlay') || $('teacher-draw-svg');
            const img = $('diagram-img');
            if (svg && G && d.bbox) {
                const iw = img ? img.offsetWidth : 800;
                const ih = img ? img.offsetHeight : 600;
                const [bx,by,bw,bh] = d.bbox;
                const cx = (bx + bw/2) * iw;
                const cy = (by + bh/2) * ih;
                const rx = (bw/2) * iw + 15;
                const ry = (bh/2) * ih + 15;
                
                // Generate a rough circle using 8 bezier points with wobble
                const rmd = () => (Math.random() - 0.5) * 10;
                const p = (a, rx, ry) => [cx + rx*Math.cos(a) + rmd(), cy + ry*Math.sin(a) + rmd()];
                
                let pathStr = `M ${cx+rx+rmd()} ${cy+rmd()} `;
                for(let i=1; i<=8; i++) {
                    const a = i * (Math.PI*2/8);
                    const [nx, ny] = p(a, rx, ry);
                    pathStr += `L ${nx} ${ny} `;
                }
                pathStr += "Z";
                
                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('d', pathStr);
                path.setAttribute('fill', 'none');
                path.setAttribute('stroke', d.color || '#FFD700');
                path.setAttribute('stroke-width', '4');
                path.setAttribute('stroke-linecap', 'round');
                path.setAttribute('stroke-linejoin', 'round');
                path.setAttribute('opacity', '0.85');
                svg.appendChild(path);
                
                const len = path.getTotalLength ? path.getTotalLength() : 1000;
                path.style.strokeDasharray = len;
                path.style.strokeDashoffset = len;
                
                G.to(path, {strokeDashoffset:0, duration:0.8, ease:'power2.inOut'});
                G.to(path, {opacity:0.5, duration:0.5, yoyo:true, repeat:Math.floor(durMs/1000), ease:'sine.inOut'});
                setTimeout(() => {
                    G.to(path, {opacity:0, duration:0.3, onComplete:() => { try{svg.removeChild(path);}catch(e){} }});
                }, durMs - 300);
            }
        }

        /* ── teacher_write: typewriter text ─────────────────── */
        if (t === 'teacher_write') {
            const box = $('teacher-write-box');
            if (box && d.text) {
                box.style.display = 'block';
                box.style.opacity = '1';
                box.style.left = ((d.position_x||0.6) * window.innerWidth) + 'px';
                box.style.top = ((d.position_y||0.3) * window.innerHeight) + 'px';
                box.textContent = '';
                const text = d.text;
                const charDelay = (d.duration_ms||2000) / text.length / 1000;
                let ci = 0;
                const iv = setInterval(() => {
                    box.textContent += text[ci]; ci++;
                    if (ci >= text.length) clearInterval(iv);
                }, charDelay * 1000);
                setTimeout(() => {
                    if (G) G.to(box, {opacity:0, duration:0.4, onComplete:()=>{box.style.display='none';box.style.opacity='1';}});
                    else { box.style.display='none'; }
                }, durMs - 400);
            }
        }

        /* ── teacher_laser: red pulsing dot ────────────────── */
        if (t === 'teacher_laser') {
            let laser = $('laser-pointer');
            if (laser) {
                const x = (d.position_x||0.5) * window.innerWidth;
                const y = (d.position_y||0.5) * window.innerHeight;
                laser.style.display = 'block';
                laser.style.opacity = '1';
                if (G) {
                    G.to(laser, {left:x, top:y, duration:0.3, ease:'power2.out'});
                    G.to(laser, {scale:1.3, duration:0.3, yoyo:true, repeat:-1, ease:'sine.inOut'});
                } else {
                    laser.style.left = x + 'px'; laser.style.top = y + 'px';
                }
                setTimeout(() => {
                    if (G) G.killTweensOf(laser);
                    laser.style.display = 'none';
                    laser.style.opacity = '1';
                    if (G) G.set(laser, {scale:1});
                }, durMs);
            }
        }

        /* ── teacher_erase: fade all teacher drawings ──────── */
        if (t === 'teacher_erase') {
            const svg = $('teacher-draw-svg');
            if (svg && G) {
                G.to(svg.children, {opacity:0, duration:0.5, stagger:0.1,
                    onComplete:() => { while(svg.firstChild && svg.firstChild.tagName !== 'defs') svg.removeChild(svg.lastChild); }
                });
            }
        }

        /* ── diagram_flow_animate: particle along path ─────── */
        if (t === 'diagram_flow_animate') {
            const svg = $('diagram-svg-overlay');
            if (svg && G) {
                const particle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                particle.setAttribute('r', '6');
                particle.setAttribute('fill', d.particle_color || '#4F8EF7');
                particle.setAttribute('filter', 'url(#glow)');
                svg.appendChild(particle);
                const pathEl = document.getElementById(d.path_id);
                if (pathEl) {
                    G.to(particle, {motionPath:{path:pathEl, align:pathEl},
                        duration:(d.duration_ms||1500)/1000, ease:'power1.inOut',
                        repeat:d.loop ? -1 : 0,
                        onComplete:() => { try{svg.removeChild(particle);}catch(e){} }
                    });
                } else {
                    setTimeout(() => { try{svg.removeChild(particle);}catch(e){} }, durMs);
                }
            }
        }

        /* ── diagram_component_highlight: canvas spotlight ──── */
        if (t === 'diagram_component_highlight') {
            const canvas = $('diagram-canvas-overlay');
            if (canvas && d.bbox) {
                const ctx = canvas.getContext('2d');
                const cw = canvas.width, ch = canvas.height;
                const [hx,hy,hw,hh] = d.bbox;
                ctx.clearRect(0, 0, cw, ch);
                ctx.fillStyle = 'rgba(0,0,0,0.5)';
                ctx.fillRect(0, 0, cw, ch);
                ctx.clearRect(hx*cw - 5, hy*ch - 5, hw*cw + 10, hh*ch + 10);
                ctx.strokeStyle = d.color || '#C9B99A';
                ctx.lineWidth = 3;
                ctx.shadowBlur = 15;
                ctx.shadowColor = d.color || '#C9B99A';
                ctx.strokeRect(hx*cw - 5, hy*ch - 5, hw*cw + 10, hh*ch + 10);
                ctx.shadowBlur = 0;
                setTimeout(() => ctx.clearRect(0, 0, cw, ch), durMs);
            }
        }

        /* ═══════════════════════════════════════════════════════
           V13 — NEW HANDLERS (Shot Planning, Cognitive Load)
        ═══════════════════════════════════════════════════════ */

        /* ── layout_shift: ViMax-style dynamic shot framing ─── */
        if (t === 'layout_shift') {
            if (G) {
                let leftPct = 50, rightPct = 50;
                if (d.layout === 'diagram_focus') { leftPct = 30; rightPct = 70; }
                else if (d.layout === 'text_focus') { leftPct = 70; rightPct = 30; }
                else if (d.layout === 'balanced') { leftPct = 55; rightPct = 45; }
                
                // Animate CSS custom properties that control the grid template
                G.to(document.body, {
                    '--col-left': leftPct + '%',
                    '--col-right': rightPct + '%',
                    duration: 1.2,
                    ease: 'power2.inOut'
                });
            }
        }

        /* ── diagram_zoom_reset: 5-step teaching sequence ──── */
        if (t === 'diagram_zoom_reset') {
            const dWrap = $('diagram-wrap');
            if (dWrap && G) {
                G.to(dWrap, {scale: 1, x: 0, y: 0, duration: 1.5, ease: 'power2.inOut'});
            }
        }

        /* ── subtitle_dim: Cognitive load optimizer ─────────── */
        if (t === 'subtitle_dim') {
            const subBox = document.querySelector('.subtitle-box');
            if (subBox && G) {
                G.to(subBox, {opacity: d.opacity || 0.3, duration: 0.3});
                setTimeout(() => {
                    G.to(subBox, {opacity: 1, duration: 0.5});
                }, durMs || 800);
            }
        }

        /* ── scene_end: Whiteboard Wipe (REMOVED) ──────────────
           Previously this was a third scene_end handler that
           erased SVGs and faded .app-container — causing
           the scene to go completely black before capture.
           The white flash at line 89 is the only transition. ── */

    }

    /* ═══════════════════════════════════════════════════════════
       MAIN LOOP — requestAnimationFrame
    ═══════════════════════════════════════════════════════════ */
    let lastPanicCheck = 0;

    function tick() {
        const ms = now();

        for (let i = 0; i < timeline.length; i++) {
            if (!firedFlags[i] && ms >= timeline[i].start_ms) {
                firedFlags[i] = true;
                try { handleEvent(timeline[i]); } catch(e) { console.error('[Timeline]', e); }
            }
        }

        // --- WATCHDOG: Ensure visibility even if events/JS fail ---
        if (ms > lastPanicCheck + 1000) {
            lastPanicCheck = ms;
            
            // 1. Heading Fail-Safe: If scene is 15% done and heading is still invisible
            const h = $('heading-left') || q('.slide-heading');
            if (h && ms > totalMs * 0.15) {
                const hOpacity = window.getComputedStyle(h).opacity;
                if (hOpacity === '0' || h.style.color === 'transparent') {
                    h.style.color = '';
                    h.style.opacity = '1';
                }
            }

            // 2. Bullet Fail-Safe: Progressively show bullets if they are missing
            const bullets = qa('.bullet');
            bullets.forEach((b, i) => {
                const revealThreshold = (totalMs * 0.2) + (i * (totalMs * 0.1));
                if (ms > revealThreshold && !b.classList.contains('b-visible')) {
                    b.classList.add('b-visible');
                    console.warn(`[Watchdog] Panic-revealing bullet ${i}`);
                }
            });

            // 3. Diagram Fail-Safe: If has-diagram and not visible after 40%
            const dCard = $('diagram-card');
            if (dCard && ms > totalMs * 0.4 && !dCard.classList.contains('diag-visible')) {
                dCard.classList.add('diag-visible');
            }
        }

        if (ms < totalMs + 2000) {
            requestAnimationFrame(tick);
        }
    }

    /* ═══════════════════════════════════════════════════════════
       AUTO-FALLBACKS (when timeline has no explicit events)
    ═══════════════════════════════════════════════════════════ */

    function autoShowDiagram() {
        const card = $('diagram-card');
        if (!card) return;
        const hasEvent = timeline.some(e => e.event_type === 'diagram_enter');
        if (!hasEvent) {
            setTimeout(() => {
                card.classList.add('diag-visible');
                setTimeout(() => card.classList.add('diag-zoom'), 700);
            }, 1000);
        }
    }

    function autoRevealBullets() {
        const hasEvents = timeline.some(e => e.event_type === 'bullet_enter');
        if (!hasEvents) {
            qa('.bullet').forEach((b, i) => {
                setTimeout(() => {
                    b.classList.add('b-visible');
                    if (i === 0) b.classList.add('b-active');
                }, 500 + i * 800);
            });
        }
    }

    /* ─── Start everything on page load ────────────────────── */
    window.addEventListener('load', () => {
        // Force initial state
        document.body.classList.add('scene-ready');
        
        // Short delay to ensure fonts/GSAP are ready
        setTimeout(() => {
            autoShowDiagram();
            autoRevealBullets();
            requestAnimationFrame(tick);
        }, 100);
    });

})();
