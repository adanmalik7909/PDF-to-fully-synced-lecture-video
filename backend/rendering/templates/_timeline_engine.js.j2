                    // Dynamic annotation using Fabric.js (Blackboard Vector Highlights) or SVG fallback
                    if (window.fabricCanvas) {
                        const fc = window.fabricCanvas;
                        const cw = fc.width;
                        const ch = fc.height;

                        if (d.annotation_type === 'circle') {
                            const acx = cx * cw;
                            const acy = cy * ch;
                            const arx = (r.w_pct / 2) * cw + 15;
                            const ary = (r.h_pct / 2) * ch + 15;

                            // Ramanujan ellipse perimeter approximation
                            const h = Math.pow(arx - ary, 2) / Math.pow(arx + ary, 2);
                            const perimeter = Math.PI * (arx + ary) * (1 + (3 * h) / (10 + Math.sqrt(4 - 3 * h)));

                            const ell = new fabric.Ellipse({
                                left: acx - arx,
                                top: acy - ary,
                                rx: arx,
                                ry: ary,
                                fill: 'transparent',
                                stroke: d.annotation_color || '#00E5FF',
                                strokeWidth: 4,
                                shadow: new fabric.Shadow({
                                    color: d.annotation_color || '#00E5FF',
                                    blur: 15,
                                    offsetX: 0,
                                    offsetY: 0
                                }),
                                strokeDashArray: [perimeter, perimeter],
                                strokeDashOffset: perimeter,
                                selectable: false,
                                evented: false
                            });

                            fc.add(ell);
                            fc.renderAll();

                            G.to(ell, {
                                strokeDashOffset: 0,
                                duration: 1.3,
                                ease: 'power2.out',
                                onUpdate: () => fc.renderAll()
                            });

                        } else if (d.annotation_type === 'highlight_box') {
                            const rx1 = r.x_pct * cw;
                            const ry1 = r.y_pct * ch;
                            const rw = r.w_pct * cw;
                            const rh = r.h_pct * ch;

                            const perimeter = 2 * (rw + rh);

                            const rect = new fabric.Rect({
                                left: rx1,
                                top: ry1,
                                width: rw,
                                height: rh,
                                fill: 'transparent',
                                stroke: d.annotation_color || '#4F8EF7',
                                strokeWidth: 4,
                                rx: 8, // rounded corners
                                ry: 8,
                                shadow: new fabric.Shadow({
                                    color: d.annotation_color || '#4F8EF7',
                                    blur: 15,
                                    offsetX: 0,
                                    offsetY: 0
                                }),
                                strokeDashArray: [perimeter, perimeter],
                                strokeDashOffset: perimeter,
                                selectable: false,
                                evented: false
                            });

                            fc.add(rect);
                            fc.renderAll();

                            G.to(rect, {
                                strokeDashOffset: 0,
                                duration: 1.3,
                                ease: 'power2.out',
                                onUpdate: () => fc.renderAll()
                            });
                        }
