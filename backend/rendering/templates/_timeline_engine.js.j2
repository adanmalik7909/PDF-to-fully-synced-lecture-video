            // Robust Text-Based Fallback if ID matching fails due to loop index mismatch
            if (!el && d.word) {
                const wordLower = d.word.toLowerCase().replace(/[^a-z0-9]/g, '');
                // Prefer parent zoom-word-inline wrapper for text-based resolution
                const inlineWords = qa('.zoom-word-inline');
                for (let iw of inlineWords) {
                    const iwText = iw.textContent.toLowerCase().replace(/[^a-z0-9]/g, '');
                    if (iwText === wordLower || iwText.includes(wordLower) || wordLower.includes(iwText)) {
