                if (G) {
                    G.to(laser, {left:x, top:y, duration:0.3, ease:'power2.out'});
                    G.to(laser, {scale:1.3, duration:0.3, yoyo:true, repeat:-1, ease:'sine.inOut'});
                } else {
                    laser.style.left = x + 'px'; laser.style.top = y + 'px';
                }
                setTimeout(() => {
                    if (G) G.killTweensOf(laser);
                    laser.style.display = 'none';
                    laser.style.opacity = '1';
                    if (G) G.set(laser, {scale:1});
                }, durMs);
            }
        }

        /* ── teacher_erase: fade all teacher drawings ──────── */
        if (t === 'teacher_erase') {
            const svg = $('teacher-draw-svg');
            if (svg && G) {
                G.to(svg.children, {opacity:0, duration:0.5, stagger:0.1,
                    onComplete:() => { while(svg.firstChild && svg.firstChild.tagName !== 'defs') svg.removeChild(svg.lastChild); }
                });
            }
        }

        /* ── diagram_flow_animate: animated glowing arrow ─────── */
        if (t === 'diagram_flow_animate') {
            const svg = $('diagram-svg-overlay');
            if (svg && window.DIAGRAM_DATA && window.DIAGRAM_DATA.components) {
                const comps = window.DIAGRAM_DATA.components;
                const fromComp = comps.find(c => c.id === d.from_component || c.label === d.from_component);
                const toComp = comps.find(c => c.id === d.to_component || c.label === d.to_component);
                
                if (fromComp && toComp && fromComp.bbox && toComp.bbox) {
                    const wrap = $('diagram-wrapper');
                    const dw = wrap ? wrap.offsetWidth : svg.clientWidth;
                    const dh = wrap ? wrap.offsetHeight : svg.clientHeight;
                    
                    const [fx, fy, fw, fh] = fromComp.bbox;
                    const [tx, ty, tw, th] = toComp.bbox;
                    
                    const startX = (fx + fw) * dw; // right edge of from
                    const startY = (fy + fh/2) * dh;
                    const endX = tx * dw;          // left edge of to
                    const endY = (ty + th/2) * dh;
                    
                    const arrow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    const cpX = (startX + endX) / 2;
                    const pathData = `M${startX},${startY} C${cpX},${startY} ${cpX},${endY} ${endX},${endY}`;
                    
                    const color = d.particle_color || '#FFD700';
                    arrow.setAttribute('d', pathData);
                    arrow.setAttribute('stroke', color);
                    arrow.setAttribute('stroke-width', '4');
                    arrow.setAttribute('fill', 'none');
                    arrow.setAttribute('marker-end', 'url(#arrowhead)');
                    arrow.setAttribute('filter', 'url(#glow)');
                    
                    // Draw animation
                    const len = 800; // approximate length
                    arrow.style.strokeDasharray = len;
                    arrow.style.strokeDashoffset = len;
                    arrow.style.transition = `stroke-dashoffset ${(durMs||1500)/1000}s ease-in-out`;
                    
                    svg.appendChild(arrow);
                    
                    requestAnimationFrame(() => {
                        arrow.style.strokeDashoffset = '0';
                    });
                    
                    setTimeout(() => { try{svg.removeChild(arrow);}catch(e){} }, durMs || 2000);
                }
            }
        }

        /* ── diagram_component_highlight: animated glowing SVG highlight + Canvas Spotlight ──── */
        if (t === 'diagram_component_highlight') {
            const svg = $('diagram-svg-overlay');
            const canvas = $('diagram-canvas-overlay');
            if (svg && canvas && d.bbox) {
                const wrap = $('diagram-wrapper');
                const dw = wrap ? wrap.offsetWidth : svg.clientWidth;
                const dh = wrap ? wrap.offsetHeight : svg.clientHeight;
                
                const [hx, hy, hw, hh] = d.bbox;
                
                // 1. Canvas Spotlight (dimming surroundings)
                const ctx = canvas.getContext('2d');
                const cw = canvas.width, ch = canvas.height;
                ctx.clearRect(0, 0, cw, ch);
                ctx.fillStyle = 'rgba(0,0,0,0.5)';
                ctx.fillRect(0, 0, cw, ch);
                ctx.clearRect(hx*cw - 5, hy*ch - 5, hw*cw + 10, hh*ch + 10);
                
                // 2. SVG Glowing Ellipse
                const cx = (hx + hw/2) * dw;
                const cy = (hy + hh/2) * dh;
                const rx = (hw/2) * dw + 12;
                const ry = (hh/2) * dh + 12;
                
                const ellipse = document.createElementNS('http://www.w3.org/2000/svg', 'ellipse');
                ellipse.setAttribute('cx', cx);
                ellipse.setAttribute('cy', cy);
                ellipse.setAttribute('rx', rx);
                ellipse.setAttribute('ry', ry);
                
                const color = d.color || '#00E5FF';
                ellipse.setAttribute('fill', 'none');
                ellipse.setAttribute('stroke', color);
                ellipse.setAttribute('stroke-width', '4');
                ellipse.setAttribute('filter', 'url(#glow)');
                
                const len = 2 * Math.PI * Math.sqrt((rx*rx + ry*ry)/2) + 100;
                ellipse.style.strokeDasharray = len;
                ellipse.style.strokeDashoffset = len;
                ellipse.style.transition = 'stroke-dashoffset 0.8s ease-out';
                
                svg.appendChild(ellipse);
                
                requestAnimationFrame(() => {
                    ellipse.style.strokeDashoffset = '0';
                });
                
                if (G) {
                    G.to(ellipse, {opacity: 0.6, duration: 0.6, delay: 0.8, yoyo: true, repeat: -1});
                }
                
                setTimeout(() => {
                    ctx.clearRect(0, 0, cw, ch);
                    if (G) G.killTweensOf(ellipse);
                    try { svg.removeChild(ellipse); } catch(e) {}
                }, durMs || 2500);
            }
        }

        /* ═══════════════════════════════════════════════════════
           V13 — NEW HANDLERS (Shot Planning, Cognitive Load)
        ═══════════════════════════════════════════════════════ */

        /* ── layout_shift: ViMax-style dynamic shot framing ─── */
        if (t === 'layout_shift') {
            if (G) {
                let leftPct = 50, rightPct = 50;
                if (d.layout === 'diagram_focus') { leftPct = 30; rightPct = 70; }
                else if (d.layout === 'text_focus') { leftPct = 70; rightPct = 30; }
                else if (d.layout === 'balanced') { leftPct = 55; rightPct = 45; }
                
                // Animate CSS custom properties that control the grid template
                G.to(document.body, {
                    '--col-left': leftPct + '%',
                    '--col-right': rightPct + '%',
                    duration: 1.2,
                    ease: 'power2.inOut'
                });
            }
        }

        /* ── diagram_zoom_reset: 5-step teaching sequence ──── */
        if (t === 'diagram_zoom_reset') {
            const dWrap = $('diagram-wrap');
            if (dWrap && G) {
                G.to(dWrap, {scale: 1, x: 0, y: 0, duration: 1.5, ease: 'power2.inOut'});
            }
        }

        /* ── subtitle_dim: Cognitive load optimizer ─────────── */
        if (t === 'subtitle_dim') {
            const subBox = document.querySelector('.subtitle-box');
            if (subBox && G) {
                G.to(subBox, {opacity: d.opacity || 0.3, duration: 0.3});
                setTimeout(() => {
                    G.to(subBox, {opacity: 1, duration: 0.5});
                }, durMs || 800);
            }
        }

        /* ── scene_end: Whiteboard Wipe (REMOVED) ──────────────
           Previously this was a third scene_end handler that
           erased SVGs and faded .app-container — causing
           the scene to go completely black before capture.
           The white flash at line 89 is the only transition. ── */

        /* ═══════════════════════════════════════════════════════
           V15 — FORMULA & TABLE & ANIMATION BRAIN HANDLERS
        ═══════════════════════════════════════════════════════ */

        /* ── formula_step: reveal formula step with spring animation ── */
        if (t === 'formula_step') {
            const stepIdx = d.step_index;
            const el = $('formula-step-' + stepIdx);
            if (el && G) {
                el.style.display = 'block';
                G.fromTo(el,
                    {opacity: 0, scale: 0.85, y: 20},
                    {opacity: 1, scale: 1, y: 0, duration: 0.6, ease: 'back.out(1.7)'}
                );
                // Golden glow pulse
                G.to(el, {
                    boxShadow: '0 0 30px rgba(255,215,0,0.6), 0 0 60px rgba(255,215,0,0.2)',
                    duration: 0.4, delay: 0.3, yoyo: true, repeat: 1
                });
            }
        }

        /* ── table_focus: highlight row or column with golden glow ── */
        if (t === 'table_focus') {
            const focusType = d.focus_type; // 'row' or 'column'
            const focusIdx = d.focus_index;
            // Dim all rows
            qa('.table-row').forEach(r => {
                if (G) G.to(r, {opacity: 0.35, duration: 0.3});
            });
            if (focusType === 'row') {
                const row = document.querySelector('.table-row[data-row="' + focusIdx + '"]');
                if (row && G) {
                    G.to(row, {opacity: 1, duration: 0.3});
                    row.classList.add('table-row-focused');
                    G.to(row, {
                        boxShadow: '0 0 20px rgba(255,215,0,0.4), inset 0 0 10px rgba(255,215,0,0.1)',
                        duration: 0.4, delay: 0.1
                    });
                    setTimeout(() => {
                        row.classList.remove('table-row-focused');
                        qa('.table-row').forEach(r => { if (G) G.to(r, {opacity: 1, duration: 0.4}); });
                        if (G) G.to(row, {boxShadow: 'none', duration: 0.3});
                    }, durMs || 3000);
                }
            } else if (focusType === 'column') {
                const cells = qa('.table-cell[data-col="' + focusIdx + '"]');
                const headerCell = document.querySelector('.table-header-cell[data-col="' + focusIdx + '"]');
                // Restore all rows first
                qa('.table-row').forEach(r => { if (G) G.to(r, {opacity: 1, duration: 0.3}); });
                // Highlight column cells
                cells.forEach(cell => {
                    if (G) G.to(cell, {
                        background: 'rgba(255,215,0,0.15)',
                        boxShadow: '0 0 15px rgba(255,215,0,0.3)',
                        duration: 0.4
                    });
                });
                if (headerCell && G) {
                    G.to(headerCell, {
                        background: 'rgba(255,215,0,0.3)',
                        duration: 0.4
                    });
                }
                setTimeout(() => {
                    cells.forEach(cell => {
                        if (G) G.to(cell, {background: 'transparent', boxShadow: 'none', duration: 0.3});
                    });
                    if (headerCell && G) G.to(headerCell, {background: '', duration: 0.3});
                }, durMs || 3000);
            }
        }

        /* ── zoom_to_region: Animation Brain pan/zoom with annotations ── */
        if (t === 'zoom_to_region') {
            const vp = $('diagram-viewport') || $('diagram-zoom-target') || $('diagram-wrapper');
            const img = $('diagram-img');
            
            // Translate bbox to region if missing
            if (vp && !d.region && d.bbox) {
                const [bx, by, bw, bh] = d.bbox;
                d.region = { x_pct: bx, y_pct: by, w_pct: bw, h_pct: bh };
            }
            
            if (vp && d.region) {
                const r = d.region;
                const scale = d.zoom_scale || 2.0;
                const vpW = vp.offsetWidth || 1800;
                const vpH = vp.offsetHeight || 780;
                const cx = r.x_pct + r.w_pct / 2;
                const cy = r.y_pct + r.h_pct / 2;
                let tx = (0.5 - cx) * vpW;
                let ty = (0.5 - cy) * vpH;
                const maxTx = (vpW * (scale - 1)) / (2 * scale);
                const maxTy = (vpH * (scale - 1)) / (2 * scale);
                tx = Math.max(-maxTx, Math.min(maxTx, tx));
                ty = Math.max(-maxTy, Math.min(maxTy, ty));
                if (G) {
                    G.to(vp, {scale: scale, x: tx, y: ty, transformOrigin: '50% 50%', duration: 0.8, ease: 'power2.inOut'});
                }
                // Draw annotation
                if (d.annotation_type === 'circle') {
                    const svg = $('diagram-svg-overlay');
                    if (svg && img) {
                        const iw = img.offsetWidth || 800;
                        const ih = img.offsetHeight || 600;
                        const acx = cx * iw, acy = cy * ih;
                        const arx = (r.w_pct / 2) * iw + 12;
                        const ary = (r.h_pct / 2) * ih + 12;
                        const ell = document.createElementNS('http://www.w3.org/2000/svg', 'ellipse');
                        ell.setAttribute('cx', acx); ell.setAttribute('cy', acy);
                        ell.setAttribute('rx', arx); ell.setAttribute('ry', ary);
                        ell.setAttribute('fill', 'none');
                        ell.setAttribute('stroke', d.annotation_color || '#00E5FF');
                        ell.setAttribute('stroke-width', '3');
                        ell.setAttribute('filter', 'url(#glow)');
                        const len = 2 * Math.PI * Math.sqrt((arx*arx + ary*ary)/2);
                        ell.style.strokeDasharray = len;
                        ell.style.strokeDashoffset = len;
                        ell.style.transition = 'stroke-dashoffset 0.6s ease-out';
                        svg.appendChild(ell);
                        requestAnimationFrame(() => { ell.style.strokeDashoffset = '0'; });
                        setTimeout(() => { try{svg.removeChild(ell);}catch(e){} }, d.hold_ms || 2500);
                    }
                } else if (d.annotation_type === 'highlight_box') {
                    let hBox = $('spatial-highlight');
                    if (!hBox) {
                        hBox = document.createElement('div');
                        hBox.id = 'spatial-highlight';
                        hBox.className = 'spatial-highlight-box';
                        hBox.style.position = 'absolute'; hBox.style.pointerEvents = 'none';
                        vp.appendChild(hBox);
                    }
                    if (img) {
                        hBox.style.left = (r.x_pct * 100) + '%';
                        hBox.style.top = (r.y_pct * 100) + '%';
                        hBox.style.width = (r.w_pct * 100) + '%';
                        hBox.style.height = (r.h_pct * 100) + '%';
                    }
                    if (G) G.fromTo(hBox, {opacity:0}, {opacity:1, duration:0.4});
                    setTimeout(() => { if (G) G.to(hBox, {opacity:0, duration:0.3}); }, d.hold_ms || 2500);
                }
                // Floating label
                if (d.region_label) {
                    let popup = $('diagram-label-popup');
                    if (!popup) {
                        popup = document.createElement('div');
                        popup.id = 'diagram-label-popup';
                        popup.className = 'diagram-label-popup';
                        vp.appendChild(popup);
                    }
                    popup.textContent = d.region_label;
                    popup.style.left = (cx * 100) + '%';
                    popup.style.top = Math.max(r.y_pct * 100 - 5, 2) + '%';
                    popup.style.display = 'block';
                    requestAnimationFrame(() => popup.classList.add('popup-visible'));
                    setTimeout(() => { popup.classList.remove('popup-visible'); setTimeout(() => popup.style.display = 'none', 400); }, d.hold_ms || 2500);
                }
                // Auto zoom out
                setTimeout(() => {
                    if (G) G.to(vp, {scale: 1, x: 0, y: 0, duration: 0.7, ease: 'power2.inOut'});
                }, d.hold_ms || 2500);
            }
        }

    }

    /* ═══════════════════════════════════════════════════════════
       MAIN LOOP — requestAnimationFrame
    ═══════════════════════════════════════════════════════════ */
    let lastPanicCheck = 0;

    function tick() {
        const ms = now();

        for (let i = 0; i < timeline.length; i++) {
            if (!firedFlags[i] && ms >= timeline[i].start_ms) {
                firedFlags[i] = true;
                try { handleEvent(timeline[i]); } catch(e) { console.error('[Timeline]', e); }
            }
        }

        // --- WATCHDOG: Ensure visibility even if events/JS fail ---
        if (ms > lastPanicCheck + 1000) {
            lastPanicCheck = ms;
            
            // 1. Heading Fail-Safe: If scene is 15% done and heading is still invisible
            const h = $('heading-left') || q('.slide-heading');
            if (h && ms > totalMs * 0.15) {
                const hOpacity = window.getComputedStyle(h).opacity;
                if (hOpacity === '0' || h.style.color === 'transparent') {
                    h.style.color = '';
                    h.style.opacity = '1';
                }
            }

            // 2. Bullet Fail-Safe: Progressively show bullets if they are missing
            const bullets = qa('.bullet');
            bullets.forEach((b, i) => {
                const revealThreshold = (totalMs * 0.2) + (i * (totalMs * 0.1));
                if (ms > revealThreshold && !b.classList.contains('b-visible')) {
                    b.classList.add('b-visible');
                    const spans = b.querySelectorAll('.word-span');
                    if (spans.length > 0 && G) {
                        G.killTweensOf(spans);
                        G.set(spans, {opacity: 1, y: 0, filter: 'blur(0px)'});
                    }
                    console.warn(`[Watchdog] Panic-revealing bullet ${i}`);
                }
            });

            // 3. Diagram Fail-Safe: If has-diagram and not visible after 40%
            const dCard = $('diagram-card');
            if (dCard && ms > totalMs * 0.4 && !dCard.classList.contains('diag-visible')) {
                dCard.classList.add('diag-visible');
            }
        }

        if (ms < totalMs + 2000) {
            requestAnimationFrame(tick);
        }
    }

    /* ═══════════════════════════════════════════════════════════
       AUTO-FALLBACKS (when timeline has no explicit events)
    ═══════════════════════════════════════════════════════════ */

    function autoShowDiagram() {
        const card = $('diagram-card');
        if (!card) return;
        const hasEvent = timeline.some(e => e.event_type === 'diagram_enter');
        if (!hasEvent) {
            setTimeout(() => {
                card.classList.add('diag-visible');
                setTimeout(() => card.classList.add('diag-zoom'), 700);
            }, 1000);
        }
    }

    function autoRevealBullets() {
        const hasEvents = timeline.some(e => e.event_type === 'bullet_enter');
        if (!hasEvents) {
            qa('.bullet').forEach((b, i) => {
                setTimeout(() => {
                    b.classList.add('b-visible');
                    if (i === 0) b.classList.add('b-active');
                }, 500 + i * 800);
            });
        }
    }

    /* ─── Start everything on page load ────────────────────── */
    window.addEventListener('load', () => {
        // Force initial state
        document.body.classList.add('scene-ready');
        
        // Short delay to ensure fonts/GSAP are ready
        setTimeout(() => {
            autoShowDiagram();
            autoRevealBullets();
            requestAnimationFrame(tick);
        }, 100);
    });

})();
