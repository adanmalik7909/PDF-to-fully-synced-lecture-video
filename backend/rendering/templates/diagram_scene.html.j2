<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SmartStudyInstructor — Diagram Focus</title>
    <style>
        {% include '_base.css.j2' %}

        /* ── Scene Layout ────────────────────────────────────── */
        .diag-header {
            position: absolute;
            top: 36px; left: 60px; right: 60px;
            font-family: 'Playfair Display', serif;
            font-size: clamp(34px, 3.4vw, 48px);
            font-weight: 700;
            color: var(--white);
            letter-spacing: -0.5px;
            z-index: 10;
            text-shadow: 0 2px 20px rgba(0,0,0,0.4);
        }

        /* ── Diagram Stage ───────────────────────────────────── */
        /* The stage clips overflowing zoom animations. It is 
           deliberately large but contained so nothing escapes the frame. */
        .diag-stage {
            position: absolute;
            left: 60px; top: 120px;
            width: 1800px; height: 780px;
            background: rgba(12, 18, 35, 0.95);
            border-radius: 24px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
            border: 1px solid rgba(79,142,247,0.2);
            overflow: hidden; /* CRITICAL: clips zoom so diagram never leaves screen */
            z-index: 5;
        }

        /* ── Diagram Viewport ─────────────────────────────────
           The viewport is a sub-container that holds the image and all overlays.
           We apply GSAP transforms to this element, NOT the image directly.
           This gives us pan+zoom while the stage clip keeps it on-screen. */
        #diagram-viewport {
            position: absolute;
            width: 100%; height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            transform-origin: center center;
            will-change: transform;
        }

        #diagram-img {
            max-width: 94%;
            max-height: 94%;
            object-fit: contain;
            border-radius: 8px;
            display: block;
            filter: brightness(0.98) contrast(1.02);
            /* NO transform here — transforms go on #diagram-viewport */
        }

        /* ── Overlay Layers (positioned over diagram-viewport) ─ */
        #diagram-canvas-overlay,
        #diagram-svg-overlay {
            position: absolute;
            top: 0; left: 0;
            pointer-events: none;
            z-index: 15;
        }

        /* ── Spatial Pointer ─────────────────────────────────── */
        #spatial-pointer {
            position: absolute;
            width: 28px; height: 28px;
            display: none;
            z-index: 30;
            transform: translate(-50%, -50%);
            pointer-events: none;
        }
        .ptr-ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 3px solid #4F8EF7;
            animation: ptr-pulse 1s ease-in-out infinite;
        }
        .ptr-dot {
            position: absolute;
            width: 10px; height: 10px;
            border-radius: 50%;
            background: #FFD700;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 12px #FFD700;
        }
        .ptr-label {
            position: absolute;
            bottom: 34px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(10,20,45,0.92);
            color: #FFD700;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
            white-space: nowrap;
            border: 1px solid rgba(79,142,247,0.4);
            letter-spacing: 0.3px;
        }

        /* UPGRADE A: CURSOR GROUNDING SYSTEM */
        #cursor-dot {
            position: fixed;
            width: 18px;
            height: 18px;
            z-index: 200;
            background: rgba(0,229,255,0.9);
            box-shadow: 0 0 12px 6px rgba(0,229,255,0.5);
            border-radius: 50%;
            pointer-events: none;
            opacity: 0; /* Hidden by default */
            transform: translate(-50%, -50%);
        }

        @keyframes ptr-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.6); opacity: 0.3; }
        }

        /* ── Highlight Box ───────────────────────────────────── */
        .spatial-highlight-box {
            position: absolute;
            border: 3px solid #4F8EF7;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(79,142,247,0.5), inset 0 0 30px rgba(79,142,247,0.08);
            pointer-events: none;
            z-index: 20;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        /* ── Floating Label Popup ────────────────────────────── */
        .diagram-label-popup {
            position: absolute;
            background: linear-gradient(135deg, rgba(10,20,45,0.96), rgba(20,35,70,0.96));
            color: #FFFFFF;
            padding: 8px 18px;
            border-radius: 24px;
            font-family: 'Inter', sans-serif;
            font-size: 17px;
            font-weight: 700;
            letter-spacing: 0.3px;
            border: 1px solid rgba(79,142,247,0.5);
            box-shadow: 0 8px 30px rgba(0,0,0,0.5), 0 0 20px rgba(79,142,247,0.2);
            z-index: 40;
            white-space: nowrap;
            transform: translateY(8px);
            opacity: 0;
            transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
            pointer-events: none;
        }
        .diagram-label-popup.popup-visible {
            opacity: 1;
            transform: translateY(0);
        }
        .diagram-label-popup::before {
            content: '▶';
            margin-right: 8px;
            color: #4F8EF7;
            font-size: 12px;
        }

        /* ── Takeaway Bar ────────────────────────────────────── */
        #takeaway-bar {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            background: linear-gradient(135deg, rgba(20,40,80,0.98), rgba(30,60,120,0.98));
            border-top: 1px solid rgba(79,142,247,0.3);
            padding: 18px 40px;
            display: flex;
            align-items: center;
            gap: 16px;
            z-index: 25;
            transform: translateY(100%);
            opacity: 0;
            transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.5s ease;
        }
        #takeaway-bar.takeaway-visible {
            transform: translateY(0);
            opacity: 1;
        }
        .takeaway-label {
            background: linear-gradient(135deg, #4F8EF7, #7FB3FF);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            font-size: 15px;
            letter-spacing: 1px;
            text-transform: uppercase;
            white-space: nowrap;
        }
        .takeaway-text {
            color: rgba(255,255,255,0.92);
            font-size: 19px;
            font-weight: 500;
            line-height: 1.4;
        }

        /* ── "Spotlight" attention box ───────────────────────── */
        #attention-hook-box {
            position: fixed;
            top: 44px; right: 60px;
            display: none;
            align-items: center;
            gap: 12px;
            padding: 14px 22px;
            border-radius: 16px;
            background: linear-gradient(135deg, rgba(30,50,100,0.98), rgba(20,35,80,0.98));
            border: 1px solid rgba(79,142,247,0.5);
            box-shadow: 0 8px 40px rgba(0,0,0,0.4), 0 0 20px rgba(79,142,247,0.2);
            z-index: 100;
        }
        .hook-icon { font-size: 22px; }
        .hook-text {
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            font-weight: 600;
            max-width: 280px;
            line-height: 1.4;
        }

        /* ── Scene Fade-in ───────────────────────────────────── */
        body { opacity: 0; }
        #diagram-zoom-wrapper {
            transform-origin: center center;
            will-change: transform;
            transition: none;
        }
        #annotation-svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 200;
            overflow: visible;
        }
        /* cursor-dot already exists but we ensure styles match */
        #cursor-dot {
            position: fixed;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: rgba(0, 229, 255, 0.9);
            box-shadow: 0 0 0 4px rgba(0,229,255,0.25), 0 0 16px 6px rgba(0,229,255,0.4);
            pointer-events: none;
            z-index: 500;
            opacity: 0;
            transform: translate(-50%, -50%);
        }
    </style>
    {% include '_gsap_head.html.j2' %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
</head>
<body>
<script>window.TIMELINE_DATA = {{ timeline_data | tojson }};</script>

<div id="analogy-overlay"></div>
<div id="attention-hook-box"></div>

<h1 class="diag-header playfair">{{ scene.heading_right or scene.heading_left }}</h1>

<div class="diag-stage" id="diag-stage">
    {% if scene.diagram_paths %}
    <!-- The viewport is what we pan+zoom. Stage clips it. -->
    <div id="diagram-viewport">

        <div id="diagram-zoom-wrapper" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative;">
            <img id="diagram-img"
                 src="{{ scene.diagram_paths[0] }}"
                 alt="Lecture Diagram"
                 onload="_initDiagramOverlays(this)">
            <svg id="annotation-svg"></svg>
        </div>

        <!-- Canvas: spotlight/dim effects -->
        <canvas id="diagram-canvas-overlay"></canvas>

        <!-- SVG: arrows, circles, underlines -->
        <svg id="diagram-svg-overlay">
          <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="7"
                    refX="9" refY="3.5" orient="auto">
              <polygon points="0 0, 10 3.5, 0 7" fill="#4F8EF7"/>
            </marker>
            <filter id="glow">
              <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
              <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
        </svg>

        <!-- Spatial pointer: pulsing dot + label -->
        <div id="spatial-pointer">
          <div class="ptr-ring"></div>
          <div class="ptr-dot"></div>
          <div class="ptr-label"></div>
        </div>

    </div><!-- end diagram-viewport -->

    <!-- Takeaway bar sits inside stage but outside viewport so it stays put -->
    <div id="takeaway-bar">
        <span class="takeaway-label inter">Key Takeaway</span>
        <span class="takeaway-text inter">{{ scene.takeaway }}</span>
    </div>

    {% else %}
    <div style="color: rgba(255,255,255,0.4); font-size: 28px; display:flex; align-items:center; justify-content:center; height:100%">
        No diagram provided for this scene.
    </div>
    {% endif %}
    
    <!-- UPGRADE A: Cursor Grounding Element -->
    <div id="cursor-dot"></div>
</div>

{% if scene.avatar_path and not (scene.avatar_config and scene.avatar_config.hidden_for_ffmpeg) %}
<div id="avatar-ring" style="position: absolute; border: 2px solid rgba(74,144,217,0.5); border-radius: 50%; opacity: 0; pointer-events: none; z-index: 50;"></div>
<img id="avatar" src="{{ scene.avatar_path }}" alt="Instructor" style="position: absolute; border-radius: 50%; object-fit: cover; opacity: 0; pointer-events: none; z-index: 50;" />
{% endif %}

<!-- Scene Transition Flash -->
<div id="scene-flash" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; opacity: 0; pointer-events: none; z-index: 9999;"></div>

<script>
/* ── Diagram overlay sizing ─────────────────────────────── */
let fabricCanvas = null;

function _initDiagramOverlays(img) {
    const canvasEl = document.getElementById('diagram-canvas-overlay');
    const svg    = document.getElementById('diagram-svg-overlay');
    if (!canvasEl || !svg) return;

    // Size canvas to match natural image dimensions (for pixel-perfect highlights)
    const width = img.naturalWidth || img.offsetWidth || 800;
    const height = img.naturalHeight || img.offsetHeight || 600;

    canvasEl.width  = width;
    canvasEl.height = height;
    // Match CSS display size to image
    canvasEl.style.width  = img.offsetWidth  + 'px';
    canvasEl.style.height = img.offsetHeight + 'px';
    canvasEl.style.left   = img.offsetLeft   + 'px';
    canvasEl.style.top    = img.offsetTop    + 'px';

    svg.setAttribute('viewBox', `0 0 ${img.offsetWidth} ${img.offsetHeight}`);
    svg.style.width  = img.offsetWidth  + 'px';
    svg.style.height = img.offsetHeight + 'px';
    svg.style.left   = img.offsetLeft   + 'px';
    svg.style.top    = img.offsetTop    + 'px';

    // Initialize Fabric static canvas
    if (window.fabric) {
        if (window.fabricCanvas) {
            try { window.fabricCanvas.dispose(); } catch(e) {}
        }
        window.fabricCanvas = new fabric.StaticCanvas('diagram-canvas-overlay', {
            width: width,
            height: height
        });
        fabricCanvas = window.fabricCanvas;
    }

    // Signal to timeline engine that overlays are ready
    window._overlaysReady = true;
}
</script>

<!-- ── Diagram Intelligence JS Helpers ── -->
<script>
// ── Diagram Intelligence Variables ──────────────────────────
let diagramImgEl = document.getElementById('diagram-img');
let diagramImgW = 0;
let diagramImgH = 0;
let diagramPanelRect = null;
let annotationSVG = document.getElementById('annotation-svg');
let cursorDot = document.getElementById('cursor-dot');

function initDiagramCoords() {
  if (!diagramImgEl) return;
  diagramImgW = diagramImgEl.naturalWidth || diagramImgEl.offsetWidth;
  diagramImgH = diagramImgEl.naturalHeight || diagramImgEl.offsetHeight;
  diagramPanelRect = diagramImgEl.getBoundingClientRect();
}

function regionToPixels(region) {
  if (!diagramPanelRect) initDiagramCoords();
  const r = diagramPanelRect || diagramImgEl.getBoundingClientRect();
  return {
    x: r.left + region.x_pct * r.width,
    y: r.top  + region.y_pct * r.height,
    w: region.w_pct * r.width,
    h: region.h_pct * r.height,
    cx: r.left + (region.x_pct + region.w_pct / 2) * r.width,
    cy: r.top  + (region.y_pct + region.h_pct / 2) * r.height
  };
}

function zoomToRegion(region, scale, durationSec) {
  const wrapper = document.getElementById('diagram-zoom-wrapper') || document.getElementById('diagram-viewport');
  if (!wrapper) return;
  const imgRect = diagramImgEl.getBoundingClientRect();
  const regionCX = (region.x_pct + region.w_pct / 2) * imgRect.width;
  const regionCY = (region.y_pct + region.h_pct / 2) * imgRect.height;
  const imgCX = imgRect.width / 2;
  const imgCY = imgRect.height / 2;
  gsap.to(wrapper, {
    scale: scale,
    x: (imgCX - regionCX) * scale,
    y: (imgCY - regionCY) * scale,
    duration: durationSec || 0.9,
    ease: 'power3.inOut'
  });
}

function zoomOut(durationSec) {
  const wrapper = document.getElementById('diagram-zoom-wrapper') || document.getElementById('diagram-viewport');
  if (!wrapper) return;
  gsap.to(wrapper, { scale: 1, x: 0, y: 0, duration: durationSec || 0.8, ease: 'power2.inOut' });
}

function drawCircleAnnotation(region, color) {
  if (!annotationSVG) return;
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const offsetX = imgRect.left - svgRect.left;
  const offsetY = imgRect.top  - svgRect.top;
  const cx = offsetX + (region.x_pct + region.w_pct/2) * imgRect.width;
  const cy = offsetY + (region.y_pct + region.h_pct/2) * imgRect.height;
  const rx = region.w_pct * imgRect.width / 2 + 10;
  const ry = region.h_pct * imgRect.height / 2 + 10;
  const circ = document.createElementNS('http://www.w3.org/2000/svg','ellipse');
  circ.setAttribute('cx', cx); circ.setAttribute('cy', cy);
  circ.setAttribute('rx', rx); circ.setAttribute('ry', ry);
  circ.setAttribute('fill','none');
  circ.setAttribute('stroke', color || '#00E5FF');
  circ.setAttribute('stroke-width','3');
  circ.setAttribute('opacity','0');
  const perim = 2 * Math.PI * Math.sqrt((rx*rx+ry*ry)/2);
  circ.setAttribute('stroke-dasharray', perim);
  circ.setAttribute('stroke-dashoffset', perim);
  annotationSVG.appendChild(circ);
  gsap.to(circ, { opacity:1, strokeDashoffset:0, duration:1.3, ease:'power2.out' });
  setTimeout(() => { gsap.to(circ, { opacity:0, duration:0.4, onComplete:()=>circ.remove() }); }, 4000);
}

function drawHighlightBox(region, color) {
  if (!annotationSVG) return;
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const x = (imgRect.left - svgRect.left) + region.x_pct * imgRect.width - 6;
  const y = (imgRect.top  - svgRect.top)  + region.y_pct * imgRect.height - 6;
  const w = region.w_pct * imgRect.width + 12;
  const h = region.h_pct * imgRect.height + 12;
  const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');
  rect.setAttribute('x',x); rect.setAttribute('y',y);
  rect.setAttribute('width',w); rect.setAttribute('height',h);
  rect.setAttribute('rx','6'); rect.setAttribute('fill', color+'22' || '#FF444422');
  rect.setAttribute('stroke', color || '#FF4444');
  rect.setAttribute('stroke-width','2.5');
  rect.setAttribute('opacity','0');
  annotationSVG.appendChild(rect);
  gsap.to(rect, { opacity:1, duration:0.4, ease:'power2.out',
    onComplete: () => gsap.to(rect, { opacity:1, yoyo:true, repeat:1, duration:0.5, delay:0.8,
      onComplete: () => setTimeout(()=>{ gsap.to(rect,{opacity:0,duration:0.4,onComplete:()=>rect.remove()})},3000) }) });
}

function drawFlowArrow(fromRegion, toRegion, label, color) {
  if (!annotationSVG) return;
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const ox = imgRect.left - svgRect.left;
  const oy = imgRect.top  - svgRect.top;
  const x1 = ox + (fromRegion.x_pct + fromRegion.w_pct) * imgRect.width;
  const y1 = oy + (fromRegion.y_pct + fromRegion.h_pct/2) * imgRect.height;
  const x2 = ox + toRegion.x_pct * imgRect.width;
  const y2 = oy + (toRegion.y_pct + toRegion.h_pct/2) * imgRect.height;
  const arrowColor = color || '#FFD700';
  const markerId = 'arr_' + Date.now();
  const defs = annotationSVG.querySelector('defs') || annotationSVG.insertBefore(document.createElementNS('http://www.w3.org/2000/svg','defs'), annotationSVG.firstChild);
  defs.innerHTML += `<marker id="${markerId}" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M2 1L8 5L2 9" fill="none" stroke="${arrowColor}" stroke-width="1.5" stroke-linecap="round"/></marker>`;
  const pathLen = Math.sqrt((x2-x1)**2+(y2-y1)**2);
  const line = document.createElementNS('http://www.w3.org/2000/svg','line');
  line.setAttribute('x1',x1); line.setAttribute('y1',y1);
  line.setAttribute('x2',x2); line.setAttribute('y2',y2);
  line.setAttribute('stroke',arrowColor); line.setAttribute('stroke-width','3');
  line.setAttribute('marker-end',`url(#${markerId})`);
  line.setAttribute('stroke-dasharray',pathLen); line.setAttribute('stroke-dashoffset',pathLen);
  line.setAttribute('opacity','0');
  annotationSVG.appendChild(line);
  gsap.to(line, { opacity:1, strokeDashoffset:0, duration:0.8, ease:'power2.inOut' });
  if (label) {
    const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
    txt.setAttribute('x',(x1+x2)/2); txt.setAttribute('y',(y1+y2)/2 - 10);
    txt.setAttribute('text-anchor','middle'); txt.setAttribute('fill',arrowColor);
    txt.setAttribute('font-size','13'); txt.setAttribute('opacity','0');
    txt.textContent = label;
    annotationSVG.appendChild(txt);
    gsap.to(txt, { opacity:1, duration:0.4, delay:0.7 });
  }
  setTimeout(()=>{ gsap.to([line], { opacity:0, duration:0.4, onComplete:()=>{ line.remove(); } }) }, 5000);
}

function moveCursor(region) {
  if (!cursorDot) cursorDot = document.getElementById('cursor-dot');
  if (!cursorDot) return;
  const px = regionToPixels(region);
  if (parseFloat(cursorDot.style.opacity||0) === 0) {
    gsap.set(cursorDot, { left: px.cx, top: px.cy });
    gsap.to(cursorDot, { opacity:1, duration:0.3 });
  } else {
    gsap.to(cursorDot, { left: px.cx, top: px.cy, duration:0.65, ease:'power2.inOut' });
  }
  gsap.fromTo(cursorDot, { scale:1 }, { scale:1.8, duration:0.3, ease:'power2.out',
    onComplete: ()=>gsap.to(cursorDot,{scale:1,duration:0.2}) });
}

function clearAnnotations() {
  if (annotationSVG) {
    while (annotationSVG.lastChild && annotationSVG.lastChild.tagName !== 'defs') {
      annotationSVG.removeChild(annotationSVG.lastChild);
    }
  }
  if (cursorDot) gsap.to(cursorDot, { opacity:0, duration:0.3 });
}

if (diagramImgEl) {
  diagramImgEl.onload = initDiagramCoords;
  if (diagramImgEl.complete) initDiagramCoords();
}
</script>

<!-- ── V12.5 GSAP Timeline Engine ── -->
<script>
    {% include '_timeline_engine.js.j2' %}
</script>

<!-- UPGRADE A: Cursor Grounding Logic -->
<script>
document.addEventListener("DOMContentLoaded", () => {
    if (typeof window.TIMELINE_DATA === "undefined" || !window.TIMELINE_DATA.events) return;
    
    const events = window.TIMELINE_DATA.events;
    const cursorEvents = events.filter(e => e.event_type === "cursor_move");
    if (cursorEvents.length === 0) return;

    const cursor = document.getElementById("cursor-dot");
    if (!cursor) return;

    let pulseTween = null;
    let isFirstMove = true;

    cursorEvents.forEach((ev) => {
        const tMs = ev.start_ms;
        const img = document.getElementById('diagram-img');
        const stage = document.getElementById('diag-stage');
        let targetX = 0; let targetY = 0;
        
        // If values are <= 1.0, they are normalized percentages from the new logic
        if (ev.details.target_x <= 1.0 && ev.details.target_y <= 1.0) {
            const rect = img ? img.getBoundingClientRect() : (stage ? stage.getBoundingClientRect() : {left:576, top:120, width:1264, height:780});
            targetX = rect.left + (ev.details.target_x * rect.width);
            targetY = rect.top + (ev.details.target_y * rect.height);
        } else {
            // Fallback for old cached absolute pixels
            targetX = ev.details.target_x;
            targetY = ev.details.target_y;
        }

        setTimeout(() => {
            if (isFirstMove) {
                gsap.set(cursor, { opacity: 0.8, x: targetX, y: targetY });
                isFirstMove = false;
            }

            // Pause pulse while moving
            if (pulseTween) pulseTween.pause();

            gsap.to(cursor, {
                x: targetX,
                y: targetY,
                duration: 0.6,
                ease: "power2.inOut",
                onComplete: () => {
                    // Trigger Ripple Effect
                    gsap.fromTo(cursor, 
                        { scale: 1, opacity: 0.8 }, 
                        { scale: 2.5, opacity: 0, duration: 0.5, ease: "power1.out",
                          onComplete: () => {
                              gsap.set(cursor, { scale: 1, opacity: 0.8 });
                              // Resume or start idle pulse
                              if (!pulseTween) {
                                  pulseTween = gsap.fromTo(cursor, 
                                      { scale: 1 }, 
                                      { scale: 1.3, yoyo: true, repeat: -1, duration: 1.2, ease: "sine.inOut" }
                                  );
                              } else {
                                  pulseTween.resume();
                              }
                          }
                        }
                    );
                }
            });
        }, tMs);
    });
});
</script>
</body>
</html>
