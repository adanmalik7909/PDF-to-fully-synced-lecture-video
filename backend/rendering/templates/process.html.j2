<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SmartStudyInstructor — {{ scene.topic }}</title>
    <style>
        {% include '_base.css.j2' %}

        /* Process template: step-by-step flow */
        .process-layout {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            padding: 60px 80px 100px;
            z-index: 10;
        }
        .process-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 36px;
        }
        .process-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(36px, 3.5vw, 48px);
            font-weight: 700;
            color: var(--white);
        }
        .process-body {
            display: flex;
            gap: 48px;
            flex: 1;
            align-items: stretch;
        }
        .process-steps-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0;
        }
        .process-diagram-col {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .step-card {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            padding: 20px 24px;
            background: rgba(255,255,255,0.04);
            border-radius: 14px;
            border: 1px solid rgba(255,255,255,0.08);
            opacity: 0;
            transform: translateX(30px);
            transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
                        background 0.3s ease, border-color 0.3s ease;
            margin-bottom: 12px;
            position: relative;
        }
        .step-card.b-visible {
            opacity: 0.7 !important;
            transform: translateX(0) !important;
        }
        .step-card.b-active {
            opacity: 1 !important;
            background: rgba(201, 185, 154, 0.1) !important;
            border-color: rgba(201, 185, 154, 0.4) !important;
            box-shadow: 0 4px 20px rgba(201, 185, 154, 0.15);
        }
        .step-card.b-done {
            opacity: 0.35 !important;
        }
        .step-card-num {
            flex-shrink: 0;
            width: 40px; height: 40px;
            border-radius: 50%;
            background: rgba(201, 185, 154, 0.15);
            color: var(--gold);
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            font-weight: 800;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.3s ease;
        }
        .step-card.b-active .step-card-num {
            background: var(--gold);
            color: var(--navy);
            transform: scale(1.1);
        }
        .step-card-text {
            font-family: 'Inter', sans-serif;
            font-size: 19px;
            line-height: 1.5;
            color: rgba(255,255,255,0.75);
            padding-top: 8px;
            transition: color 0.3s ease;
        }
        .step-card.b-active .step-card-text {
            color: rgba(255,255,255,0.95) !important;
        }
        /* Step connector line */
        .step-card::before {
            content: '';
            position: absolute;
            left: 43px; top: -12px;
            width: 2px; height: 12px;
            background: rgba(201, 185, 154, 0.2);
        }
        .step-card:first-child::before { display: none; }
    </style>
    {% include '_gsap_head.html.j2' %}
</head>
<body>
<script>window.TIMELINE_DATA = {{ timeline_data | tojson }};</script>

<div id="analogy-overlay"></div>
<div id="kb-target" style="position: absolute; inset: 0; z-index: 0;"></div>

<div class="process-layout">
    <!-- Header -->
    <div class="process-header">
        <div class="topic-chip inter">{{ scene.topic }}</div>
        <div class="scene-counter" style="position: static;">
            Scene {{ "%02d"|format(scene.scene_index) }} /
            {{ "%02d"|format(scene.total_scenes) }}
        </div>
    </div>

    <h1 class="process-title playfair slide-heading" id="heading-left">
        {% set heading = scene.heading_left %}
        {% if scene.gold_word %}
            {% set heading = heading | replace(scene.gold_word,
                '<span class="gold-word">' ~ scene.gold_word ~ '</span>', 1) %}
        {% endif %}
        {{ heading | safe }}
    </h1>

    <!-- Step Indicator Bar -->
    <div class="process-steps" id="step-indicators">
        {% for bullet in scene.bullets %}
        <div class="process-step-indicator">
            <div class="step-circle" id="step-circle-{{ loop.index0 }}">{{ loop.index }}</div>
            {% if not loop.last %}
            <div class="step-connector" id="step-conn-{{ loop.index0 }}"></div>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    <div class="process-body">
        <!-- Step Cards -->
        <div class="process-steps-col" id="bullets-zone">
            {% for bullet in scene.bullets %}
            {% if bullet is mapping %}
            <div class="step-card bullet" data-index="{{ loop.index0 }}" id="bullet_{{ loop.index0 }}">
                <div class="step-card-num">{{ "%02d"|format(loop.index) }}</div>
                <div class="step-card-text inter">
                    {% set btext = bullet.text or '' %}
                    {% if bullet.zoom_word %}
                        {% set btext = btext | replace(bullet.zoom_word,
                            '<span class="zoom-word-inline" id="zw_' ~ loop.index0 ~ '">'
                            ~ bullet.zoom_word ~ '</span>', 1) %}
                    {% endif %}
                    {{ btext | wordwrap_spans | safe }}
                </div>
            </div>
            {% else %}
            <div class="step-card bullet" data-index="{{ loop.index0 }}" id="bullet_{{ loop.index0 }}">
                <div class="step-card-num">{{ "%02d"|format(loop.index) }}</div>
                <div class="step-card-text inter">{{ bullet | wordwrap_spans | safe }}</div>
            </div>
            {% endif %}
            {% endfor %}
        </div>

        <!-- Diagram (if present) -->
        {% if scene.diagram_paths %}
        <div class="process-diagram-col">
            <div id="diagram-card" class="diagram-card" style="position: relative; right: auto; top: auto; transform: none; width: 100%; height: 100%; max-width: 520px; max-height: 440px;">
                <div class="diagram-card-header">
                    <div class="diagram-dot red"></div>
                    <div class="diagram-dot amber"></div>
                    <div class="diagram-dot green"></div>
                    <span style="margin-left:8px;">Diagram</span>
                </div>
                <div id="diagram-zone" class="diagram-zone">
                    <div id="diagram-wrapper" class="diagram-wrapper" style="overflow: hidden;">
                        <div id="diagram-zoom-target" style="position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                            <img id="diagram-img" src="{{ scene.diagram_paths[0] }}" alt="Diagram" class="diagram-img" onload="initDiagramOverlays(this)">
                            <canvas id="diagram-canvas-overlay" class="diagram-overlay-canvas"></canvas>
                            <svg id="diagram-svg-overlay" class="diagram-overlay-svg">
                                <defs>
                                    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                                        <polygon points="0 0, 10 3.5, 0 7" fill="#4F8EF7"/>
                                    </marker>
                                </defs>
                            </svg>
                            <svg id="annotation-layer" class="diagram-overlay-svg" style="opacity:0;">
                                <circle id="annotation-circle" cx="200" cy="200" r="80" stroke="#00E5FF" stroke-width="3" fill="none" />
                                <path id="annotation-arrow" d="M 200 120 Q 260 60 320 100" stroke="#00E5FF" stroke-width="3" fill="none" marker-end="url(#arrowhead)" />
                            </svg>
                            <div id="spatial-pointer" class="spatial-pointer" style="display:none">
                                <div class="ptr-ring"></div>
                                <div class="ptr-dot"></div>
                                <div class="ptr-label"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <script>
                function initDiagramOverlays(img) {
                    const canvas = document.getElementById('diagram-canvas-overlay');
                    const svg = document.getElementById('diagram-svg-overlay');
                    const annLayer = document.getElementById('annotation-layer');
                    const w = img.offsetWidth, h = img.offsetHeight;
                    if (canvas) {
                        canvas.width = img.naturalWidth;
                        canvas.height = img.naturalHeight;
                        canvas.style.width = w + 'px';
                        canvas.style.height = h + 'px';
                    }
                    if(svg) {
                        svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
                        svg.style.width = w + 'px';
                        svg.style.height = h + 'px';
                    }
                    if(annLayer) {
                        annLayer.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
                        annLayer.style.width = w + 'px';
                        annLayer.style.height = h + 'px';
                        // Reposition annotation elements to center of actual image
                        const circle = document.getElementById('annotation-circle');
                        const arrow = document.getElementById('annotation-arrow');
                        if (circle) { circle.setAttribute('cx', w/2); circle.setAttribute('cy', h/2); circle.setAttribute('r', Math.min(w,h)*0.2); }
                        if (arrow) { arrow.setAttribute('d', 'M ' + w/2 + ' ' + h*0.3 + ' Q ' + w*0.6 + ' ' + h*0.1 + ' ' + w*0.8 + ' ' + h*0.2); }
                    }
                }
                </script>
            </div>
        </div>
        {% endif %}
    </div>
</div>

{% if scene.avatar_path and not (scene.avatar_config and scene.avatar_config.hidden_for_ffmpeg) %}
<div id="avatar-ring" style="position: absolute; border: 2px solid rgba(74,144,217,0.5); border-radius: 50%; opacity: 0; pointer-events: none; z-index: 50;"></div>
<img id="avatar" src="{{ scene.avatar_path }}" alt="Instructor" style="position: absolute; border-radius: 50%; object-fit: cover; opacity: 0; pointer-events: none; z-index: 50;" />
{% endif %}

<!-- Scene Transition Flash -->
<div id="scene-flash" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; opacity: 0; pointer-events: none; z-index: 9999;"></div>

<!-- NOTE: Subtitles burned by FFmpeg SRT -->

<div id="takeaway-bar">
    <span class="takeaway-icon">💡</span>
    <span class="takeaway-label inter">Key Takeaway</span>
    <span class="takeaway-text inter">{{ scene.takeaway }}</span>
</div>

<!-- Step indicator animation (sync with bullet events) -->
<script>
(function() {
    // Watch for bullet state changes and update step indicators
    const observer = new MutationObserver(function() {
        document.querySelectorAll('.step-card').forEach(function(card, i) {
            const circle = document.getElementById('step-circle-' + i);
            const conn = document.getElementById('step-conn-' + i);
            if (!circle) return;

            if (card.classList.contains('b-active')) {
                circle.className = 'step-circle step-active';
            } else if (card.classList.contains('b-done')) {
                circle.className = 'step-circle step-done';
                if (conn) conn.className = 'step-connector conn-done';
            } else {
                circle.className = 'step-circle';
            }
        });
    });
    document.querySelectorAll('.step-card').forEach(function(card) {
        observer.observe(card, { attributes: true, attributeFilter: ['class'] });
    });
})();
</script>

{% include '_gsap_layers.html.j2' %}

<script>{% include '_timeline_engine.js.j2' %}</script>
</body>
</html>
