{% extends '_base.html.j2' %}

{% block head %}
<style>
    .summary-fullscreen {
        width: 100%;
        height: 100%;
        position: relative;
        background: #0C1223; /* Deep navy fullscreen transition */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 100px;
        text-align: center;
        background-image: 
            radial-gradient(circle at 50% 30%, rgba(79, 142, 247, 0.08) 0%, transparent 60%),
            linear-gradient(180deg, rgba(12, 18, 35, 0.4) 0%, #0C1223 100%);
    }
    
    .summary-text-glow {
        font-family: 'Playfair Display', serif;
        font-size: 56px;
        font-weight: 800;
        line-height: 1.25;
        color: var(--white);
        max-width: 1300px;
        margin-bottom: 50px;
        opacity: 0;
        transform: scale(0.95);
        transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        text-shadow: 0 0 30px rgba(255,255,255,0.05);
    }
    
    .summary-text-glow.visible {
        opacity: 1;
        transform: scale(1);
        text-shadow: 0 0 40px rgba(255,255,255,0.12);
    }
    
    .gold-word {
        color: var(--gold);
        font-style: italic;
        text-shadow: 0 0 30px rgba(212,168,83,0.5);
    }
    
    .summary-description {
        font-family: 'Inter', sans-serif;
        font-size: 22px;
        line-height: 1.7;
        color: rgba(255,255,255,0.65);
        max-width: 900px;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s ease 0.4s;
    }
    
    .summary-description.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
{% endblock %}

{% block content %}
<div class="summary-fullscreen" id="summary-stage">
    <div class="progress-strip">
        <div class="progress-fill" style="width:{{ (scene.scene_index / scene.total_scenes * 100)|round }}%;"></div>
    </div>
    
    <div class="topic-chip" style="margin-bottom: 40px; border-color: rgba(212,168,83,0.3); color: var(--gold);">{{ scene.topic }}</div>
    
    <!-- Large centered summary statement -->
    <h1 class="summary-text-glow" id="summary-heading">
        {% set heading = scene.heading_left %}
        {% if scene.gold_word %}
            {% set heading = heading | replace(scene.gold_word, '<span class="gold-word">' ~ scene.gold_word ~ '</span>', 1) %}
        {% endif %}
        {{ heading | safe }}
    </h1>
    
    <!-- Explanatory note -->
    <p class="summary-description" id="summary-desc">
        {{ scene.takeaway }}
    </p>
    
    <div class="scene-counter" style="bottom: 80px; left: 50%; transform: translateX(-50%);">
        Scene {{ "%02d"|format(scene.scene_index) }} / {{ "%02d"|format(scene.total_scenes) }}
    </div>
</div>
{% endblock %}
